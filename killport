# ── Tool implementations ─────────────────────────────────

def sh(cmd, inp=None, timeout=30):
    try:
        r = subprocess.run(cmd, input=inp, capture_output=True, text=True, timeout=timeout)
        return (r.stdout + r.stderr)[:2500]
    except subprocess.TimeoutExpired: return "(timed out)"
    except Exception as e: return f"(error: {e})"

def has(tool): return subprocess.run(["which",tool],capture_output=True).returncode==0

SENSITIVE_PATHS=["/admin","/admin/","/administrator","/login","/login.php","/wp-admin",
    "/wp-login.php","/phpmyadmin","/pma","/config","/.env","/backup","/api/v1","/api/v2",
    "/console","/manager","/actuator/env","/metrics","/status","/.git/HEAD","/server-status"]

def tool_scan(port):
    ensure_port(port)
    if has("nmap"):
        out = sh(["nmap","-sV","-sC","-p",port,"--open","-T4",TARGET],timeout=45)
        findings[port]["raw_scan"] = out
        # extract version
        for line in out.splitlines():
            if f"{port}/tcp" in line:
                parts = line.split()
                if len(parts)>=4:
                    findings[port]["service"] = parts[2]
                    findings[port]["version"]  = " ".join(parts[3:])
        return out
    return sh(["nc","-z","-w3",TARGET,port])

def tool_banner(port):
    ensure_port(port)
    try:
        r = subprocess.run(["nc","-w3",TARGET,port],input="\r\n",
            capture_output=True,text=True,timeout=6)
        b = r.stdout[:600] or "(no banner)"
        findings[port]["banner"] = b
        # look for hashes in banner
        for m in re.findall(r'\$[126]\$\S+|[a-f0-9]{32,64}', b):
            if m not in findings[port]["hashes"]:
                findings[port]["hashes"].append(m)
        return b
    except: return "(failed)"

def tool_http_probe(port, path="/"):
    ensure_port(port)
    scheme = "https" if port in ("443","8443") else "http"
    out = sh(["curl","-sk","--max-time","6","-i","-L","--max-redirs","2",
              f"{scheme}://{TARGET}:{port}{path}"])
    for m in re.findall(r'\$[126]\$\S+|[a-f0-9]{32,64}', out):
        if m not in findings[port]["hashes"]:
            findings[port]["hashes"].append(m)
    return out[:1500]

def tool_http_paths(port):
    ensure_port(port)
    scheme = "https" if port in ("443","8443") else "http"
    found=[]
    for path in SENSITIVE_PATHS:
        r = subprocess.run(["curl","-sk","--max-time","4","-o","/dev/null",
            "-w","%{http_code}",f"{scheme}://{TARGET}:{port}{path}"],
            capture_output=True,text=True,timeout=6)
        code=r.stdout.strip()
        if code not in ("404","000","","400"):
            found.append(f"{code}  {path}")
    findings[port]["paths_found"].extend(found)
    return "\n".join(found) if found else "no sensitive paths found"

def tool_try(service,port,user,passwd):
    ensure_port(port)
    s=service.lower()
    res="failed"
    if s=="ssh":
        if not has("sshpass"): return "sshpass not installed — skipped"
        r=subprocess.run(["sshpass","-p",passwd,"ssh","-o","StrictHostKeyChecking=no",
            "-o","ConnectTimeout=2","-o","BatchMode=no","-o","LogLevel=ERROR",
            f"{user}@{TARGET}","exit"],capture_output=True,text=True,timeout=5)
        res="LOGIN SUCCEEDED" if r.returncode==0 else "failed"
    elif s in ("http","https","web"):
        scheme="https" if port in ("443","8443") else "http"
        r=subprocess.run(["curl","-sk","--max-time","4","-o","/dev/null","-w","%{http_code}",
            "-u",f"{user}:{passwd}",f"{scheme}://{TARGET}:{port}/"],
            capture_output=True,text=True,timeout=6)
        code=r.stdout.strip()
        res=f"HTTP {code} — SUCCESS" if code in ("200","302","301","303") else "failed"
    elif s=="ftp":
        r=subprocess.run(["curl","-s","--max-time","5",f"ftp://{user}:{passwd}@{TARGET}/"],
            capture_output=True,text=True,timeout=7)
        res="LOGIN SUCCEEDED" if (r.returncode==0 and "530" not in r.stderr) else "failed"
    elif s=="redis":
        r=subprocess.run(["nc","-w3",TARGET,port],input=f"AUTH {passwd}\r\nPING\r\nQUIT\r\n",
            capture_output=True,text=True,timeout=5)
        if "+OK" in r.stdout and "+PONG" in r.stdout:
            res=f"password '{passwd}' ACCEPTED"
        else:
            r2=subprocess.run(["nc","-w3",TARGET,port],input="PING\r\nQUIT\r\n",
                capture_output=True,text=True,timeout=5)
            if "+PONG" in r2.stdout:
                findings[port]["no_auth"]=True
                res="NO AUTH REQUIRED"
    elif s in ("mysql",):
        if not has("mysql"): return "mysql client not installed"
        r=subprocess.run(["mysql","-h",TARGET,"-P",port,"-u",user,f"-p{passwd}",
            "--connect-timeout=3","-e","SELECT 1;"],capture_output=True,text=True,timeout=8)
        res="LOGIN SUCCEEDED" if r.returncode==0 else "failed"
    elif s in ("postgres","postgresql","pg"):
        if not has("psql"): return "psql not installed"
        env={**os.environ,"PGPASSWORD":passwd}
        r=subprocess.run(["psql","-h",TARGET,"-p",port,"-U",user,"-c","\\q"],
            capture_output=True,text=True,timeout=8,env=env)
        res="LOGIN SUCCEEDED" if r.returncode==0 else "failed"
    if "SUCCEEDED" in res or "ACCEPTED" in res:
        cred=f"{user}:{passwd}"
        if cred not in findings[port]["creds_ok"]:
            findings[port]["creds_ok"].append(cred)
    return res

def tool_wordlist(service, port):
    ensure_port(port)
    hits=[]
    # redis no-auth check first
    if service.lower()=="redis":
        r=subprocess.run(["nc","-w3",TARGET,port],input="PING\r\nQUIT\r\n",
            capture_output=True,text=True,timeout=5)
        if "+PONG" in r.stdout:
            findings[port]["no_auth"]=True
            return "CRITICAL: Redis has NO password — fully open to anyone"
    total=len(TOP_USERS)*len(TOP_PASSES); done=0; bar_w=30
    for user in TOP_USERS:
        for pw in TOP_PASSES:
            done+=1
            pct=done*100//total
            filled=done*bar_w//total
            bar="\u2588"*filled+"\u2591"*(bar_w-filled)
            sys.stdout.write(f"  \033[2m[{bar}] {pct:3d}%  testing {service}/{user}\033[0m\r")
            sys.stdout.flush()
            res=tool_try(service,port,user,pw)
            if "SUCCEEDED" in res or "ACCEPTED" in res or "NO AUTH" in res:
                hits.append(f"  \u2713 {user}:{pw or '(empty)'}  \u2192  {res}")
                if len(hits)>=3: break
        if len(hits)>=3: break
    sys.stdout.write("  " + " "*60 + "\r"); sys.stdout.flush()
    return "\n".join(hits) if hits else "no credentials from wordlist succeeded"

def tool_nmap_script(port, script):
    if not has("nmap"): return "nmap not installed"
    out=sh(["nmap","-p",port,f"--script={script}","-T4",TARGET],timeout=60)
    ensure_port(port)
    findings[port]["notes"].append(f"nmap {script}: {out[:200]}")
    return out

def tool_crack(h):
    h=h.strip()
    import tempfile
    hf=tempfile.NamedTemporaryFile(mode='w',suffix='.hash',delete=False)
    hf.write(h+"\n"); hf.close()
    # detect type
    ht=""; flag=""
    if re.match(r'^[a-f0-9]{32}$',h,re.I):   ht="MD5";         flag="--hash-type=0"
    elif re.match(r'^[a-f0-9]{40}$',h,re.I): ht="SHA1";        flag="--hash-type=100"
    elif re.match(r'^[a-f0-9]{64}$',h,re.I): ht="SHA256";      flag="--hash-type=1400"
    elif re.match(r'^\$2[aby]\$',h):          ht="bcrypt";      flag="--hash-type=3200"
    elif re.match(r'^\$1\$',h):               ht="MD5crypt";    flag="--hash-type=500"
    elif re.match(r'^\$6\$',h):               ht="SHA512crypt"; flag="--hash-type=1800"
    wl="/usr/share/wordlists/rockyou.txt"
    if not os.path.exists(wl): wl="/usr/share/dict/words"
    out=""
    if has("hashcat") and flag and os.path.exists(wl):
        r=subprocess.run(["hashcat",flag,hf.name,wl,"--quiet","--potfile-disable",
            "--outfile-format=2","--runtime=20"],
            capture_output=True,text=True,timeout=25)
        if r.returncode==0 and r.stdout.strip():
            out=f"CRACKED: {r.stdout.strip().splitlines()[-1]}"
    elif has("john") and os.path.exists(wl):
        subprocess.run(["john",f"--wordlist={wl}",hf.name],
            capture_output=True,text=True,timeout=25)
        r2=subprocess.run(["john","--show",hf.name],
            capture_output=True,text=True,timeout=5)
        if r2.stdout.strip(): out=f"CRACKED: {r2.stdout.strip()}"
    os.unlink(hf.name)
    result = out or f"could not crack — hash type: {ht or 'unknown'}"
    # store in relevant port
    for p,d in findings.items():
        if h in d["hashes"] and out:
            d["cracked"].append(f"{h[:20]}... → {out}")
    return result

# ── Ollama helpers ────────────────────────────────────────
def ollama_chat(msgs):
    """Stream response from Ollama, display live token progress, strip think blocks."""
    payload=json.dumps({"model":MODEL,"messages":msgs,"stream":True})
    try:
        proc=subprocess.Popen(
            ["curl","-sN",f"http://{OLLAMA}/api/chat",
             "-H","Content-Type: application/json","--data-binary",payload],
            stdout=subprocess.PIPE,stderr=subprocess.DEVNULL,text=True)
    except Exception: return ""
    full=""; tok=0; in_think=False
    SP=["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    try:
        for raw in iter(proc.stdout.readline,""):
            raw=raw.strip()
            if not raw: continue
            try:
                obj=json.loads(raw)
                t=obj.get("message",{}).get("content","")
                if t:
                    full+=t; tok+=1
                    if "<think>" in t: in_think=True
                    if "</think>" in t: in_think=False
                    lbl="thinking" if in_think else "generating"
                    sys.stdout.write(f"\r  {D}{SP[tok%len(SP)]}  {tok} tokens  [{lbl}]{R}   ")
                    sys.stdout.flush()
                if obj.get("done",False): break
            except json.JSONDecodeError: pass
    except Exception: pass
    finally:
        try: proc.stdout.close()
        except: pass
        try: proc.wait(timeout=5)
        except: proc.kill()
    sys.stdout.write("\r"+" "*50+"\r"); sys.stdout.flush()
    full=re.sub(r'<think>.*?</think>','',full,flags=re.DOTALL)
    full=re.sub(r'^.*?</think>\s*','',full,flags=re.DOTALL)
    full=re.sub(r'<think>.*$','',full,flags=re.DOTALL)
    return full.strip()

def ai_report(case_file):
    now = datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
    header = [
        "═"*62,
        f"  SECURITY REPORT  ·  {TARGET}  ·  {now}",
        f"  Model: {MODEL}",
        "═"*62,
        ""
    ]
    port_lines = []
    for port,data in sorted(findings.items(),key=lambda x:int(x[0]) if x[0].isdigit() else 0):
        rl = risk_level(data)
        svc = data["service"] or "unknown"
        ver = f" ({data['version']})" if data["version"] else ""
        issues = []
        if data["no_auth"]: issues.append("NO PASSWORD — anyone can connect")
        for c in data["creds_ok"]: issues.append(f"weak credential works: {c}")
        for c in data["cracked"]: issues.append(f"hash cracked: {c}")
        if data["paths_found"]: issues.append(f"exposed paths: {', '.join(data['paths_found'][:3])}")
        status = "; ".join(issues) if issues else "open, no critical issues found"
        port_lines.append(f"  Port {port} — {svc.upper()}{ver}  [{RISK_ICON[rl]}]  {status}")
    case_text = "\n\n".join(case_file) if case_file else "Initial scan only."
    report_msgs = [
        {"role":"system","content":(
            "You are a security analyst writing a penetration test report. "
            "Write in clear plain English that a non-technical person can understand. "
            "Do not use markdown # headers. Use plain section labels in ALL CAPS."
        )},
        {"role":"user","content":(
            f"Target: {TARGET}\n\n"
            "Port overview:\n" + "\n".join(port_lines) + "\n\n"
            f"Full investigation log:\n{case_text[:5000]}\n\n"
            "Write a complete security report with exactly these four sections:\n"
            "EXECUTIVE SUMMARY\n"
            "FINDINGS (cover each port: service name, risk level, plain-English explanation)\n"
            "WHAT TO DO FIRST (numbered list, most critical action first)\n"
            "ADDITIONAL HARDENING (3-5 general recommendations)"
        )}
    ]
    body = ollama_chat(report_msgs)
    return "\n".join(header) + body + "\n"

