# ── watch ────────────────────────────────────────────────

watch_port() {
  local port="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  [ -z "$port" ] && { printf "\n  ${Y}Usage: killport watch <port>${R}\n\n"; return 1; }

  printf "\n${B}${C}  killport watch${R}  ${D}port %s  (Ctrl+C to stop)${R}\n" "$port"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  ${D}%-10s  %-26s  %-14s  %s${R}\n" "TIME" "REMOTE" "STATE" "PROCESS"
  printf "  ${D}%s${R}\n" "──────────────────────────────────────────────────────────"

  local seen=()
  local _stty; _stty=$(stty -g 2>/dev/null) || _stty=""
  trap '[ -n "$_stty" ] && stty "$_stty" 2>/dev/null || stty sane 2>/dev/null; printf "\n\n"; exit 0' INT TERM

  while true; do
    local raw_conns=""
    if command -v ss &>/dev/null; then
      raw_conns=$(ss -tnp "sport = :${port} or dport = :${port}" 2>/dev/null | tail -n +2 || true)
    else
      raw_conns=$(netstat -tn 2>/dev/null | grep -E "\b${port}\b" || true)
    fi
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      local state="" remote="" proc="-" ts
      ts=$(date "+%H:%M:%S")
      if command -v ss &>/dev/null; then
        state=$(awk '{print $1}' <<< "$line")
        remote=$(awk '{print $5}' <<< "$line")
        proc=$(awk '{print $6}' <<< "$line" | grep -oE '"[^"]+"' | tr -d '"' | head -1 || echo "-")
      else
        state=$(awk '{print $6}' <<< "$line")
        remote=$(awk '{print $5}' <<< "$line")
      fi
      local key="${remote}|${state}"
      local already=0
      for sv in "${seen[@]:-}"; do [ "$sv" = "$key" ] && already=1 && break; done
      if [ "$already" -eq 0 ]; then
        seen+=("$key")
        local sc="$G"
        [[ "$state" == "CLOSE_WAIT" || "$state" == "TIME_WAIT" ]] && sc="$Y"
        [[ "$state" == "SYN_RECV" ]] && sc="$RE"
        printf "  %-10s  %-26s  ${sc}%-14s${R}  ${D}%s${R}\n" "$ts" "$remote" "$state" "$proc"
      fi
    done <<< "$raw_conns"
    sleep 0.5
  done
}

# ── cert ─────────────────────────────────────────────────

cert_check() {
  local target="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  [ -z "$target" ] && { printf "\n  ${Y}Usage: killport cert <host:port> or <domain>${R}\n\n"; return 1; }
  command -v openssl &>/dev/null || { printf "\n  ${Y}openssl not found.${R}\n\n"; return 1; }

  local host port
  if [[ "$target" == *:* ]]; then host="${target%:*}"; port="${target##*:}"
  else host="$target"; port="443"; fi

  printf "\n${B}${C}  killport cert${R}  ${D}%s:%s${R}\n" "$host" "$port"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  ${D}Connecting...${R}\n\n"

  local raw_cert hs _to=""
  command -v gtimeout &>/dev/null && _to="gtimeout 6"
  command -v timeout  &>/dev/null && _to="timeout 6"
  raw_cert=$(echo "Q" | ${_to} openssl s_client -connect "${host}:${port}" \
    -servername "$host" 2>/dev/null) || true
  hs=$(echo "$raw_cert" | grep -E "Protocol|Cipher" | head -4 || true)
  local cert_info
  cert_info=$(echo "$raw_cert" | openssl x509 -noout \
    -subject -issuer -dates -fingerprint -ext subjectAltName 2>/dev/null) || true

  if [ -z "$cert_info" ]; then
    printf "  ${RE}Could not retrieve certificate from %s:%s${R}\n\n" "$host" "$port"; return 1
  fi

  local not_after subject issuer
  not_after=$(grep "notAfter"   <<< "$cert_info" | cut -d= -f2 || true)
  subject=$(grep   "^subject"   <<< "$cert_info" | sed 's/subject=//' || true)
  issuer=$(grep    "^issuer"    <<< "$cert_info" | sed 's/issuer=//'  || true)
  local sans=()
  while IFS= read -r s; do
    [[ "$s" == *"DNS:"* ]] && sans+=("$(echo "$s" | tr ',' '\n' | grep "DNS:" | sed 's/.*DNS://;s/ //g')")
  done < <(grep -A2 "subjectAltName" <<< "$cert_info" | tail -1 | tr ',' '\n' || true)

  local days_left="" exp_color="$G"
  if [ -n "$not_after" ]; then
    local exp_epoch now_epoch
    if date -j &>/dev/null 2>&1; then
      exp_epoch=$(date -j -f "%b %d %T %Y %Z" "$not_after" "+%s" 2>/dev/null) || exp_epoch=""
    else
      exp_epoch=$(date -d "$not_after" "+%s" 2>/dev/null) || exp_epoch=""
    fi
    now_epoch=$(date "+%s")
    [ -n "$exp_epoch" ] && days_left=$(( (exp_epoch - now_epoch) / 86400 ))
    [ -n "$days_left" ] && [ "$days_left" -lt 90 ] && exp_color="$Y"
    [ -n "$days_left" ] && [ "$days_left" -lt 30 ] && exp_color="$RE"
  fi

  printf "  ${B}Subject :${R}  ${D}%s${R}\n" "$subject"
  printf "  ${B}Issuer  :${R}  ${D}%s${R}\n" "$issuer"
  printf "  ${B}Expires :${R}  ${exp_color}%s" "$not_after"
  [ -n "$days_left" ] && printf "  (%d days)" "$days_left"
  printf "${R}\n"

  if [ "${#sans[@]}" -gt 0 ]; then
    printf "  ${B}SANs    :${R}\n"
    for s in "${sans[@]}"; do
      while IFS= read -r san; do [ -n "$san" ] && printf "    ${D}%s${R}\n" "$san"; done <<< "$s"
    done
  fi

  if [ -n "$hs" ]; then
    printf "\n"
    while IFS= read -r line; do [ -n "$line" ] && printf "  ${D}%s${R}\n" "$line"; done <<< "$hs"
  fi
  printf "\n"
}

