# ── Code: opencode launcher ───────────────────────────────────────────────────

code_dispatch() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  local subcmd="${1:-}"

  local OC_CONF_DIR="$HOME/.config/opencode"
  local OC_CONF="$OC_CONF_DIR/opencode.json"

  # ── tool-calling tier for a given model name ─────────────────────────────────
  # returns: "full" | "limited" | "none"
  _code_model_tier() {
    local m; m=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')
    case "$m" in
      *qwen2.5-coder*|*qwen3*|*qwen3.*|*deepseek-coder*|*deepseek-r1*|*granite-code*) printf "full" ;;
      *codellama*|*starcoder*|*codegemma*|*gemma3*|*gemma4*|*llama3*) printf "limited" ;;
      *) printf "none" ;;
    esac
  }

  _code_tier_label() {
    case "$1" in
      full)    printf "${G}✓ full tool-calling${R}" ;;
      limited) printf "${Y}⚠ limited tool-calling${R}" ;;
      *)       printf "${RE}✗ no tool-calling${R}" ;;
    esac
  }

  # ── install opencode ─────────────────────────────────────────────────────────
  _code_install() {
    printf "\n${B}${C}  Install opencode${R}\n\n"
    if ! command -v brew &>/dev/null; then
      _ensure_homebrew || true
    fi
    if command -v brew &>/dev/null; then
      printf "  ${D}Trying: brew install opencode${R}\n\n"
      brew install opencode && {
        printf "\n  ${G}✓ opencode installed via Homebrew.${R}\n\n"; return 0
      }
    fi
    if command -v npm &>/dev/null; then
      printf "  ${D}Trying: npm install -g opencode-ai${R}\n\n"
      npm install -g opencode-ai && {
        printf "\n  ${G}✓ opencode installed via npm.${R}\n\n"; return 0
      }
    fi
    printf "  ${RE}✗ Could not auto-install. Install manually:${R}\n\n"
    printf "  ${C}brew install opencode${R}   ${D}or${R}   ${C}npm install -g opencode-ai${R}\n\n"
    return 1
  }

  # ── write ~/.config/opencode/opencode.json ────────────────────────────────────
  _code_write_conf() {
    local ollama_host="$1" model="$2"
    local base_url
    if [[ "$ollama_host" =~ ^https?:// ]]; then
      base_url="${ollama_host}/v1"
    else
      base_url="http://${ollama_host}/v1"
    fi
    mkdir -p "$OC_CONF_DIR"
    python3 -c "
import json, sys
conf_path, base_url, model = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(conf_path) as f: conf = json.load(f)
except Exception: conf = {}
conf.setdefault('provider', {})
conf['provider']['ollama'] = {'options': {'baseURL': base_url}, 'models': {model: {}}}
conf['model'] = 'ollama/' + model
with open(conf_path, 'w') as f: json.dump(conf, f, indent=2); f.write('\n')
" "$OC_CONF" "$base_url" "$model" 2>/dev/null || {
      printf "  ${RE}✗ Failed to write opencode config (python3 required).${R}\n\n"; return 1
    }
  }

  # ── interactive model picker ──────────────────────────────────────────────────
  # sets global _CODE_MODEL on success, returns 1 on failure/cancel
  _CODE_MODEL=""
  _code_pick_model() {
    local ollama_host="$1"
    local tags_json
    tags_json=$(curl -sf --max-time 4 "http://${ollama_host}/api/tags" 2>/dev/null || true)

    if [ -z "$tags_json" ]; then
      printf "\n  ${RE}✗ Cannot reach Ollama at %s${R}\n\n" "$ollama_host"
      printf "  ${D}Check that Ollama is running: ollama serve${R}\n\n"
      return 1
    fi

    local -a _names=()
    while IFS= read -r _mn; do [ -n "$_mn" ] && _names+=("$_mn"); done \
      < <(printf '%s' "$tags_json" | python3 -c "
import json,sys
for m in json.load(sys.stdin).get('models',[]): print(m['name'])" 2>/dev/null || true)

    if [ "${#_names[@]}" -eq 0 ]; then
      printf "\n  ${Y}No models found in Ollama.${R}\n\n"
      printf "  ${D}Pull a coding model first:${R}\n\n"
      printf "  ${C}ollama pull qwen2.5-coder:7b${R}   ${D}← recommended${R}\n\n"
      return 1
    fi

    printf "\n${B}${C}  Available models on %s${R}\n\n" "$ollama_host"
    printf "  ${D}Best for opencode: qwen2.5-coder, qwen3, deepseek-coder, deepseek-r1${R}\n"
    printf "  ${D}Requires full tool-calling support to edit files and run commands.${R}\n\n"

    local i=1
    for _n in "${_names[@]}"; do
      local _tier; _tier=$(_code_model_tier "$_n")
      local _label; _label=$(_code_tier_label "$_tier")
      printf "  ${B}%2d${R}  %-35s  %b\n" "$i" "$_n" "$_label"
      (( i++ )) || true
    done
    printf "\n"

    while true; do
      local _pick
      printf "  Pick a model [1-%d] → " "${#_names[@]}"
      read -r _pick </dev/tty
      _pick="${_pick%$'\r'}"

      if ! [[ "$_pick" =~ ^[0-9]+$ ]] || [ "$_pick" -lt 1 ] || [ "$_pick" -gt "${#_names[@]}" ]; then
        printf "  ${RE}Invalid selection.${R}\n\n"; continue
      fi

      local _chosen="${_names[$(( _pick - 1 ))]}"
      local _tier; _tier=$(_code_model_tier "$_chosen")

      if [[ "$_tier" == "none" ]]; then
        printf "\n  ${Y}⚠  '%s' does not support tool calling.${R}\n" "$_chosen"
        printf "  ${D}opencode needs tool-calling to read/write files and run commands.${R}\n"
        printf "  ${D}It will work as a chat assistant only.${R}\n\n"
        printf "  Continue anyway? [y/N] → "; read -r _cont </dev/tty
        if [[ ! "$_cont" =~ ^[Yy]$ ]]; then
          printf "\n"; continue
        fi
      elif [[ "$_tier" == "limited" ]]; then
        printf "\n  ${Y}⚠  '%s' has limited tool-calling support.${R}\n" "$_chosen"
        printf "  ${D}Some opencode features may not work. Consider qwen2.5-coder or qwen3.${R}\n\n"
        printf "  Continue anyway? [Y/n] → "; read -r _cont </dev/tty
        if [[ "$_cont" =~ ^[Nn]$ ]]; then
          printf "\n"; continue
        fi
      fi

      _CODE_MODEL="$_chosen"
      break
    done
  }

  # ── install only ─────────────────────────────────────────────────────────────
  if [[ "$subcmd" == "install" ]]; then
    _code_install; return
  fi

  # ── model picker mode ─────────────────────────────────────────────────────────
  if [[ "$subcmd" == "model" ]]; then
    attack_load_conf
    _code_pick_model "$ATTACK_OLLAMA" || return 1
    printf "\n  ${G}✓ Model set to '%s'${R}\n" "$_CODE_MODEL"
    printf "  ${D}Run 'killport code' to launch.${R}\n\n"
    ATTACK_MODEL="$_CODE_MODEL"; attack_save_conf
    return
  fi

  # ── check opencode is installed ───────────────────────────────────────────────
  if ! command -v opencode &>/dev/null; then
    printf "\n  ${Y}opencode is not installed.${R}\n\n"
    printf "  Install it now? [Y/n] → "; read -r _inst </dev/tty
    if [[ ! "$_inst" =~ ^[Nn]$ ]]; then
      _code_install || return 1
    else
      printf "  ${D}Run 'killport code install' when ready.${R}\n\n"; return 1
    fi
  fi

  # ── resolve Ollama host + model ───────────────────────────────────────────────
  attack_load_conf
  local ollama_host="$ATTACK_OLLAMA"
  local model="$subcmd"    # may be empty — filled in below

  # if a bare name was passed, use it; otherwise check saved model, else pick
  if [ -z "$model" ]; then
    model="$ATTACK_MODEL"
  fi

  if [ -z "$model" ]; then
    printf "\n  ${D}No model saved yet — let's pick one.${R}\n"
    _code_pick_model "$ollama_host" || return 1
    model="$_CODE_MODEL"
    ATTACK_MODEL="$model"; attack_save_conf
  else
    # named model passed — verify tier and warn if needed
    local _tier; _tier=$(_code_model_tier "$model")
    if [[ "$_tier" == "none" ]]; then
      printf "\n  ${Y}⚠  '%s' does not support tool calling.${R}\n" "$model"
      printf "  ${D}opencode needs tool-calling to read/write files and run commands.${R}\n"
      printf "  ${D}It will work as a chat assistant only.${R}\n\n"
      printf "  Continue anyway? [y/N] → "; read -r _cont </dev/tty
      if [[ ! "$_cont" =~ ^[Yy]$ ]]; then
        printf "\n  ${D}Pick a different model:${R}\n"
        _code_pick_model "$ollama_host" || return 1
        model="$_CODE_MODEL"; ATTACK_MODEL="$model"; attack_save_conf
      fi
    elif [[ "$_tier" == "limited" ]]; then
      printf "\n  ${Y}⚠  '%s' has limited tool-calling support.${R}\n" "$model"
      printf "  ${D}Some opencode features may not work. Consider qwen2.5-coder or qwen3.${R}\n\n"
      printf "  Continue anyway? [Y/n] → "; read -r _cont </dev/tty
      if [[ "$_cont" =~ ^[Nn]$ ]]; then
        printf "\n  ${D}Pick a different model:${R}\n"
        _code_pick_model "$ollama_host" || return 1
        model="$_CODE_MODEL"; ATTACK_MODEL="$model"; attack_save_conf
      fi
    fi
  fi

  # ── write config and launch ───────────────────────────────────────────────────
  printf "\n  ${G}✓ Configuring opencode${R}\n"
  printf "  ${D}Ollama:  %s${R}\n" "$ollama_host"
  printf "  ${D}Model:   %s${R}\n\n" "$model"

  _code_write_conf "$ollama_host" "$model" || return 1

  printf "  ${D}Launching opencode...${R}\n\n"
  exec opencode
}

# ── browser ──────────────────────────────────────────────
_browser_ensure_harness() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  command -v browser-harness &>/dev/null && return 0

  printf "  ${Y}browser-harness not installed — installing now...${R}\n\n"

  # ensure uv
  if ! command -v uv &>/dev/null; then
    printf "  ${D}Installing uv...${R}\n"
    if command -v brew &>/dev/null; then
      brew install uv
    else
      curl -LsSf https://astral.sh/uv/install.sh | sh
      export PATH="$HOME/.local/bin:$PATH"
    fi
  fi

  local HARNESS_DIR="$HOME/browser-harness"
  if [ ! -d "$HARNESS_DIR/.git" ]; then
    printf "  ${D}Cloning browser-harness...${R}\n"
    git clone https://github.com/browser-use/browser-harness "$HARNESS_DIR"
  fi

  printf "  ${D}Installing browser-harness via uv...${R}\n"
  uv tool install -e "$HARNESS_DIR"

  # reload PATH so the new binary is visible
  export PATH="$(uv tool dir)/bin:$HOME/.local/bin:$PATH"

  if ! command -v browser-harness &>/dev/null; then
    printf "  ${RE}Install failed — browser-harness still not on PATH.${R}\n"
    printf "  ${D}Try opening a new terminal and running: killport browser <prompt>${R}\n\n"
    return 1
  fi

  printf "  ${G}browser-harness installed.${R}\n\n"

  # first-time browser setup
  printf "\n${B}${C}  Browser Setup — Connect to Chrome${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  browser-harness controls your browser via Chrome DevTools Protocol (CDP).\n"
  printf "  It needs to attach to a running Chrome instance with remote debugging on.\n\n"
  printf "  ${B}Step 1${R}  ${D}Make sure Google Chrome is open on your Mac.${R}\n\n"
  printf "  ${B}Step 2${R}  ${D}Chrome will open the tab chrome://inspect/#remote-debugging${R}\n"
  printf "          ${D}If the Profile Picker appears — select your normal profile.${R}\n\n"
  printf "  ${B}Step 3${R}  ${D}On that page, check the box:${R}\n"
  printf "          ${B}☑  Discover network targets${R}\n"
  printf "          ${D}Then click${R} ${B}Allow${R} ${D}if a permission dialog pops up.${R}\n\n"
  printf "  ${B}Step 4${R}  ${D}Come back here — setup will complete automatically.${R}\n\n"
  printf "  ${D}(This only needs to be done once per Chrome profile.)${R}\n\n"
  browser-harness --setup
}

browser_run() {
  local PROMPT="$*"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  attack_load_conf

  if [ -z "$PROMPT" ]; then
    printf "\n${B}${C}  killport browser${R}  ${D}AI browser automation${R}\n"
    printf "${C}  ────────────────────────────────────────────${R}\n\n"
    printf "  ${B}Usage:${R}  killport browser <prompt>\n\n"
    printf "  ${D}Examples:${R}\n"
    printf "    killport browser open google.com and search for pizza\n"
    printf "    killport browser take a screenshot of github.com/trending\n"
    printf "    killport browser fill in the login form at 127.0.0.1:3000\n\n"

    # ── status panel ────────────────────────────────────
    printf "  ${B}Status:${R}\n"

    # browser-harness
    if command -v browser-harness &>/dev/null; then
      printf "  ${G}✓${R}  browser-harness  ${D}$(command -v browser-harness)${R}\n"
    else
      printf "  ${Y}✗${R}  browser-harness  ${D}not installed${R}\n\n"
      printf "  Install browser-harness now? [Y/n] → "
      read -r _ans </dev/tty
      if [[ "${_ans:-y}" =~ ^[Yy]$ ]]; then
        printf "\n"
        _browser_ensure_harness || return 1
      else
        printf "  ${D}Skipped. Run: killport browser <prompt> to install when ready.${R}\n"
      fi
    fi

    # Ollama host
    local _host="${ATTACK_OLLAMA:-localhost:11434}"
    local _model="${ATTACK_MODEL:-}"
    local _tags
    _tags=$(curl -sf --max-time 3 "http://${_host}/api/tags" 2>/dev/null || true)

    if [ -n "$_tags" ]; then
      local _first
      _first=$(printf '%s' "$_tags" | python3 -c \
        "import json,sys; d=json.load(sys.stdin); m=d.get('models',[]); print(m[0]['name'] if m else '')" 2>/dev/null || true)
      local _display="${_model:-${_first}}"
      printf "  ${G}✓${R}  Ollama  ${D}%s${R}  model: ${B}%s${R}\n" "$_host" "${_display:-none loaded}"
    else
      if [ -n "$_model" ]; then
        printf "  ${Y}✗${R}  Ollama  ${D}configured: %s  model: %s  — unreachable (machine may be off)${R}\n" "$_host" "$_model"
      else
        printf "  ${Y}✗${R}  Ollama  ${D}not reachable at %s — run: ollama serve${R}\n" "$_host"
      fi
    fi

    printf "\n  ${D}Configure Ollama host/model: killport config${R}\n\n"
    return 0
  fi

  printf "\n${B}${C}  Browser${R}  ${D}→ %s${R}\n" "$PROMPT"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  # auto-install browser-harness if missing
  _browser_ensure_harness || return 1

  # check Ollama
  printf "  ${D}Connecting to Ollama at %s...${R}\n" "$ATTACK_OLLAMA"
  local tags_json
  tags_json=$(curl -sf --max-time 5 "http://${ATTACK_OLLAMA}/api/tags" 2>/dev/null || true)
  if [ -z "$tags_json" ]; then
    if [ -n "$ATTACK_MODEL" ]; then
      printf "  ${RE}Ollama unreachable at http://%s${R}  ${D}(configured model: %s)${R}\n" "$ATTACK_OLLAMA" "$ATTACK_MODEL"
      printf "  ${D}The machine may be off or Ollama isn't running. Try: ollama serve${R}\n\n"
    else
      printf "  ${RE}Ollama not reachable at http://%s${R}\n" "$ATTACK_OLLAMA"
      printf "  ${D}Run: ollama serve   or configure: killport config${R}\n\n"
    fi
    return 1
  fi

  local MODEL="$ATTACK_MODEL"
  if [ -z "$MODEL" ]; then
    MODEL=$(printf '%s' "$tags_json" | python3 -c \
      "import json,sys; d=json.load(sys.stdin); m=d.get('models',[]); print(m[0]['name'] if m else '')" 2>/dev/null || true)
  fi
  if [ -z "$MODEL" ]; then
    printf "  ${RE}No Ollama model found.${R} Run: ollama pull qwen2.5:14b\n\n"
    return 1
  fi

  printf "  ${G}Connected.${R}  ${D}Model: %s${R}\n\n" "$MODEL"
  printf "  ${D}Generating browser automation code...${R}\n\n"

  local SYSTEM_PROMPT='You are a browser automation expert. Write Python code for browser-harness (a CDP bridge). Available helpers are pre-imported: new_tab(url), goto(url), wait_for_load(), click(selector_or_coords), type_text(text), page_info(), screenshot(), scroll(direction, amount), find_element(selector), get_text(selector), eval_js(code). Rules: always use new_tab() for the FIRST navigation, call wait_for_load() after every navigation, use screenshot() to verify state before clicking. Return ONLY valid Python code — no markdown, no triple backticks, no explanation.'

  local _py
  _py=$(mktemp "${TMPDIR:-/tmp}/kp_browser.XXXXXX.py")

  local _prompt_esc _system_esc
  _system_esc=$(printf '%s' "$SYSTEM_PROMPT" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read())[1:-1])')
  _prompt_esc=$(printf '%s' "$PROMPT"        | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read())[1:-1])')

  curl -sf --max-time 120 "http://${ATTACK_OLLAMA}/api/generate" \
    -H "Content-Type: application/json" \
    -d "{\"model\":\"${MODEL}\",\"prompt\":\"${_system_esc}\\n\\nTask: ${_prompt_esc}\",\"stream\":false}" 2>/dev/null \
    | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('response',''))" > "$_py" 2>/dev/null || true

  # strip any accidental markdown fences
  python3 - "$_py" <<'PYSTRIP'
import sys, re, pathlib
p = pathlib.Path(sys.argv[1])
txt = p.read_text()
txt = re.sub(r'^```[^\n]*\n', '', txt, flags=re.MULTILINE)
txt = re.sub(r'```\s*$', '', txt, flags=re.MULTILINE)
p.write_text(txt.strip() + '\n')
PYSTRIP

  printf "  ${B}Generated code:${R}\n"
  printf "${D}"
  cat "$_py"
  printf "${R}\n"

  printf "  ${D}Running via browser-harness...${R}\n\n"
  browser-harness < "$_py"
  local _exit=$?
  rm -f "$_py"

  if [ $_exit -eq 0 ]; then
    printf "\n  ${G}Done.${R}\n\n"
  else
    printf "\n  ${RE}browser-harness exited with code %d${R}\n\n" "$_exit"
  fi
  return $_exit
}

case "$1" in

  setup)
    setup_wizard
    ;;

  scan)
    scan_run "${2:-}" "${3:-}"
    ;;

  watch)
    watch_port "${2:-}"
    ;;

  cert)
    cert_check "${2:-}"
    ;;

  sniff)
    sniff_port "${2:-}"
    ;;

  vuln)
    vuln_check "${2:-}"
    ;;

  fix)
    fix_dispatch "${2:-}"
    ;;

  browser)
    shift
    browser_run "$@"
    ;;

  audit)
    audit_firewall
    ;;

  dns)
    dns_recon "${2:-}"
    ;;

  forward)
    forward_port "${2:-}" "${3:-}"
    ;;

  config)
    attack_config
    ;;

  attack)
    attack_dispatch "${2:-}"
    ;;

  stress)
    stress_dispatch "${2:-}"
    ;;

  shutdown)
    shutdown_dispatch "${2:-}" "${3:-}"
    ;;

  restart)
    restart_dispatch "${2:-}"
    ;;

  code)
    code_dispatch "${2:-}"
    ;;

  qrconnect)
    qrconnect_dispatch
    ;;

  ssh)
    ssh_dispatch "${2:-}" "${3:-}"
    ;;

  wol)
    wol_dispatch "${2:-}" "${3:-}" "${4:-}" "${5:-}"
    ;;

  uninstall)
    _C=$'\033[0;36m'; _G=$'\033[0;32m'; _Y=$'\033[0;33m'; _RE=$'\033[0;31m'
    _D=$'\033[2m'; _B=$'\033[1m'; _R=$'\033[0m'

    # secure-erase a file: overwrite then delete
    _secure_rm() {
      local _f="$1"
      [ -f "$_f" ] || return 0
      if command -v srm &>/dev/null; then
        srm -f "$_f"
      else
        python3 -c "
import os, pathlib
p = pathlib.Path('$_f')
size = p.stat().st_size
with open(p, 'r+b') as fh:
    for _ in range(3):
        fh.seek(0); fh.write(os.urandom(size)); fh.flush(); os.fsync(fh.fileno())
" 2>/dev/null || true
        rm -f "$_f"
      fi
    }

    _ask() { # _ask "Question" → returns 0 for yes, 1 for no (default: no)
      printf "%s [y/N] → " "$1"
      read -r _a </dev/tty
      [[ "${_a:-n}" =~ ^[Yy]$ ]]
    }

    printf "\n${_B}${_C}  killport uninstall${_R}\n"
    printf "${_C}  ────────────────────────────────────────────${_R}\n\n"

    # ── Section 1: Installed tools ───────────────────────────
    printf "  ${_B}Installed tools${_R}\n\n"

    _tools_remove_browser=false
    _tools_remove_nmap=false
    _tools_remove_sshpass=false
    _tools_remove_hashcat=false
    _tools_remove_john=false
    _found_any_tool=false

    if command -v browser-harness &>/dev/null || [ -d "$HOME/browser-harness" ]; then
      _found_any_tool=true
      printf "  ${_Y}●${_R}  browser-harness"
      command -v browser-harness &>/dev/null && printf "  ${_D}%s${_R}" "$(command -v browser-harness)"
      [ -d "$HOME/browser-harness" ] && printf "  ${_D}+ ~/browser-harness${_R}"
      printf "\n"
      _ask "      Uninstall browser-harness?" && _tools_remove_browser=true
      printf "\n"
    fi

    if command -v nmap &>/dev/null && brew list nmap &>/dev/null 2>&1; then
      _found_any_tool=true
      printf "  ${_Y}●${_R}  nmap  ${_D}$(command -v nmap)${_R}\n"
      _ask "      Uninstall nmap?" && _tools_remove_nmap=true
      printf "\n"
    fi

    if command -v sshpass &>/dev/null && brew list sshpass &>/dev/null 2>&1; then
      _found_any_tool=true
      printf "  ${_Y}●${_R}  sshpass  ${_D}$(command -v sshpass)${_R}\n"
      _ask "      Uninstall sshpass?" && _tools_remove_sshpass=true
      printf "\n"
    fi

    if command -v hashcat &>/dev/null && brew list hashcat &>/dev/null 2>&1; then
      _found_any_tool=true
      printf "  ${_Y}●${_R}  hashcat  ${_D}$(command -v hashcat)${_R}\n"
      _ask "      Uninstall hashcat?" && _tools_remove_hashcat=true
      printf "\n"
    fi

    if command -v john &>/dev/null && brew list john &>/dev/null 2>&1; then
      _found_any_tool=true
      printf "  ${_Y}●${_R}  john  ${_D}$(command -v john)${_R}\n"
      _ask "      Uninstall john?" && _tools_remove_john=true
      printf "\n"
    fi

    [ "$_found_any_tool" = false ] && printf "  ${_D}none found${_R}\n\n"

    # ── Section 2: Saved data & config ───────────────────────
    printf "  ${_B}Saved data & config${_R}\n\n"

    # parallel arrays instead of associative array (bash 3.2 safe)
    _file_paths=()
    _file_decisions=()   # "y" or "n" per index
    _file_sensitive=()   # "1" if needs secure erase

    _print_and_ask_file() {
      local _label="$1" _path="$2" _note="${3:-}" _sens="${4:-0}"
      [ -e "$_path" ] || return 0
      printf "  ${_Y}●${_R}  %-44s${_D}%s${_R}\n" "$_label" "$_note"
      _file_paths+=("$_path")
      _file_sensitive+=("$_sens")
      if [ "$_sens" = "1" ]; then
        # two-step confirm for sensitive files
        if _ask "      Delete? (sensitive — requires confirmation)"; then
          printf "  ${_RE}  This will permanently destroy %s via 3-pass overwrite.${_R}\n" "$_path"
          if _ask "      Are you sure? This cannot be undone"; then
            _file_decisions+=("y")
          else
            printf "  ${_D}  Kept.${_R}\n"
            _file_decisions+=("n")
          fi
        else
          _file_decisions+=("n")
        fi
      else
        if _ask "      Delete?"; then
          _file_decisions+=("y")
        else
          _file_decisions+=("n")
        fi
      fi
      printf "\n"
    }

    _print_and_ask_file "attack.conf  (Ollama host + model)"    "$HOME/.config/killport/attack.conf"
    _print_and_ask_file "attack.log   (pentest history)"        "$HOME/.config/killport/attack.log"
    _print_and_ask_file "wol_hosts    (Wake-on-LAN hosts)"      "$HOME/.config/killport/wol_hosts"
    _print_and_ask_file "ssh_known    (saved SSH connections)"  "$HOME/.killport/ssh_known"
    _print_and_ask_file "shutdown_hosts"                        "$HOME/.killport/shutdown_hosts"
    _print_and_ask_file "id_ed25519   (SSH private key)"        "$HOME/.killport/id_ed25519"    "⚠  3-pass secure erase" "1"
    _print_and_ask_file "id_ed25519.pub"                        "$HOME/.killport/id_ed25519.pub" "⚠  3-pass secure erase" "1"

    _remove_config_dir=false
    _remove_killport_dir=false
    if [ -d "$HOME/.config/killport" ]; then
      _ask "  Remove folder  ~/.config/killport/" && _remove_config_dir=true
      printf "\n"
    fi
    if [ -d "$HOME/.killport" ]; then
      _ask "  Remove folder  ~/.killport/" && _remove_killport_dir=true
      printf "\n"
    fi

    # ── Section 3: System config ─────────────────────────────
    printf "  ${_B}System config${_R}\n\n"
    _pf_dirty=false
    [ -f /etc/pf.anchors/killport ] && { printf "  ${_Y}●${_R}  /etc/pf.anchors/killport\n"; _pf_dirty=true; }
    sudo grep -q 'killport' /etc/pf.conf 2>/dev/null && { printf "  ${_Y}●${_R}  /etc/pf.conf  ${_D}(killport anchor entries)${_R}\n"; _pf_dirty=true; }
    if [ "$_pf_dirty" = true ]; then
      printf "\n"
      _ask "  Remove firewall rules?" && _clean_pf=true || _clean_pf=false
    else
      printf "  ${_D}none found${_R}\n"
      _clean_pf=false
    fi
    printf "\n"

    # ── Summary ──────────────────────────────────────────────
    printf "  ${_B}Summary — will be removed:${_R}\n\n"
    _anything_selected=false

    [ "$_tools_remove_browser"  = true ] && { printf "  ${_RE}✕${_R}  browser-harness\n"; _anything_selected=true; }
    [ "$_tools_remove_nmap"     = true ] && { printf "  ${_RE}✕${_R}  nmap\n";            _anything_selected=true; }
    [ "$_tools_remove_sshpass"  = true ] && { printf "  ${_RE}✕${_R}  sshpass\n";         _anything_selected=true; }
    [ "$_tools_remove_hashcat"  = true ] && { printf "  ${_RE}✕${_R}  hashcat\n";         _anything_selected=true; }
    [ "$_tools_remove_john"     = true ] && { printf "  ${_RE}✕${_R}  john\n";            _anything_selected=true; }

    for _i in "${!_file_paths[@]}"; do
      if [ "${_file_decisions[$_i]}" = "y" ]; then
        if [ "${_file_sensitive[$_i]}" = "1" ]; then
          printf "  ${_RE}✕${_R}  %s  ${_D}(secure erase)${_R}\n" "${_file_paths[$_i]}"
        else
          printf "  ${_RE}✕${_R}  %s\n" "${_file_paths[$_i]}"
        fi
        _anything_selected=true
      fi
    done

    [ "$_remove_config_dir"  = true ] && { printf "  ${_RE}✕${_R}  ~/.config/killport/\n"; _anything_selected=true; }
    [ "$_remove_killport_dir"= true ] && { printf "  ${_RE}✕${_R}  ~/.killport/\n";        _anything_selected=true; }
    [ "$_clean_pf"           = true ] && { printf "  ${_RE}✕${_R}  firewall rules\n";      _anything_selected=true; }
    printf "  ${_RE}✕${_R}  killport  ${_D}%s${_R}\n\n" "$(command -v killport 2>/dev/null || echo '/usr/local/bin/killport')"

    if [ "$_anything_selected" = false ]; then
      printf "  ${_D}(no tools or data selected — only killport itself will be removed)${_R}\n\n"
    fi

    _ask "  Proceed?" || { printf "\n  ${_D}Aborted.${_R}\n\n"; exit 0; }
    printf "\n"

    # ── Execute ──────────────────────────────────────────────

    [ "$_tools_remove_browser" = true ] && {
      command -v browser-harness &>/dev/null && uv tool uninstall browser-harness 2>/dev/null || true
      [ -d "$HOME/browser-harness" ] && rm -rf "$HOME/browser-harness" && printf "  Removed ~/browser-harness\n"
      printf "  Removed browser-harness\n"
    }
    [ "$_tools_remove_nmap"    = true ] && brew uninstall --quiet nmap    2>/dev/null && printf "  Removed nmap\n"    || true
    [ "$_tools_remove_sshpass" = true ] && brew uninstall --quiet sshpass 2>/dev/null && printf "  Removed sshpass\n" || true
    [ "$_tools_remove_hashcat" = true ] && brew uninstall --quiet hashcat 2>/dev/null && printf "  Removed hashcat\n" || true
    [ "$_tools_remove_john"    = true ] && brew uninstall --quiet john    2>/dev/null && printf "  Removed john\n"    || true

    for _i in "${!_file_paths[@]}"; do
      [ "${_file_decisions[$_i]}" = "y" ] || continue
      _fp="${_file_paths[$_i]}"
      if [ "${_file_sensitive[$_i]}" = "1" ]; then
        _secure_rm "$_fp" && printf "  Securely erased %s\n" "$_fp"
      elif [ -f "$_fp" ]; then
        rm -f "$_fp" && printf "  Removed %s\n" "$_fp"
      fi
    done

    [ "$_remove_config_dir"   = true ] && [ -d "$HOME/.config/killport" ] && rm -rf "$HOME/.config/killport" && printf "  Removed ~/.config/killport\n"
    [ "$_remove_killport_dir" = true ] && [ -d "$HOME/.killport" ]        && rm -rf "$HOME/.killport"        && printf "  Removed ~/.killport\n"

    # firewall
    if [ "$_clean_pf" = true ]; then
      [ -f /etc/pf.anchors/killport ] && sudo rm /etc/pf.anchors/killport && printf "  Removed /etc/pf.anchors/killport\n"
      sudo grep -q 'killport' /etc/pf.conf 2>/dev/null && {
        sudo sed -i '' '/anchor "killport"/d' /etc/pf.conf
        sudo sed -i '' '/load anchor "killport"/d' /etc/pf.conf
        sudo pfctl -f /etc/pf.conf 2>/dev/null || true
        printf "  Cleaned /etc/pf.conf\n"
      }
    fi

    # killport binary
    _INSTALL_PATH=$(command -v killport 2>/dev/null || true)
    if [ -n "$_INSTALL_PATH" ] && [ -f "$_INSTALL_PATH" ]; then
      if [ -w "$_INSTALL_PATH" ]; then rm "$_INSTALL_PATH"
      else sudo rm "$_INSTALL_PATH"; fi
      printf "  Removed %s\n" "$_INSTALL_PATH"
    fi

    printf "\n  ${_G}Done.${_R}  killport has been uninstalled.\n\n"
    ;;

  update)
    echo "Checking for updates..."
    remote=$(fetch_remote_version 5)
    if [ -z "$remote" ]; then echo "Could not reach GitHub. Check your connection."; exit 1; fi
    if [ "$remote" = "$VERSION" ]; then echo "Already up to date (v${VERSION})"; exit 0; fi
    echo "Updating $VERSION → $remote..."
    INSTALL_PATH=$(command -v killport)
    if [ -w "$INSTALL_PATH" ]; then
      curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && chmod +x "$INSTALL_PATH"
    else
      sudo curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && sudo chmod +x "$INSTALL_PATH"
    fi
    echo "Updated to v${remote}. Run killport to confirm."
    ;;

  list)
    list_ports
    ;;

  openports)
    open_ports "${2:-}"
    ;;

  closedports)
    closed_ports
    ;;

  ports)
    ports_inspect
    ;;

  opencheck)
    [ -z "${2:-}" ] && { echo "Usage: killport openports <ip>"; exit 1; }
    open_ports "$2"
    ;;

  status)
    [ -z "${2:-}" ] && { echo "Usage: killport status <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    status_port "$2"
    ;;

  ip)
    show_ip
    ;;

  open)
    [ -z "${2:-}" ] && { echo "Usage: killport open <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    open_port "$2"
    ;;

  close)
    [ -z "${2:-}" ] && { echo "Usage: killport close <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    close_port "$2"
    ;;

  *)
    PORT="$1"
    if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
      if grep -q "^${PORT}|" "$HOME/.killport/ssh_known" 2>/dev/null; then
        ssh_dispatch "$PORT"
        exit 0
      fi
      echo "Error: '$PORT' is not a valid port number (1–65535)"
      exit 1
    fi
    PIDS=$(sudo lsof -ti :"$PORT" 2>/dev/null || true)
    if [ -z "$PIDS" ]; then echo "Nothing running on port $PORT"; exit 0; fi
    echo "Port $PORT is in use:"
    echo ""
    while IFS= read -r pid; do
      info=$(ps -p "$pid" -o pid=,user=,comm=,command= 2>/dev/null || true)
      if [ -n "$info" ]; then
        printf "  PID:     %s\n" "$(echo "$info" | awk '{print $1}')"
        printf "  User:    %s\n" "$(echo "$info" | awk '{print $2}')"
        printf "  Name:    %s\n" "$(echo "$info" | awk '{print $3}')"
        printf "  Command: %s\n" "$(echo "$info" | awk '{$1=$2=$3=""; sub(/^ +/, ""); print}')"
        echo ""
      fi
    done <<< "$PIDS"
    echo "$PIDS" | xargs kill -9
    echo "Killed."
    ;;

esac
