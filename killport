#!/usr/bin/env bash

set -euo pipefail

usage() {
  echo "Usage: killport <port>"
  echo "       killport list"
  exit 1
}

if [ $# -eq 0 ]; then
  echo "Usage: killport <port>"
  echo "       killport list"
  echo ""
  echo "Listening ports:"
  echo ""
  lsof -iTCP -iUDP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {printf "  %-8s %-10s %-10s %s\n", $9, $1, $2, $8}' | sort -t: -k2 -n
  exit 0
fi

# --- list all listening ports ---
if [ "$1" = "list" ]; then
  echo "Listening ports:"
  echo ""
  lsof -iTCP -iUDP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {printf "  %-8s %-10s %-10s %s\n", $9, $1, $2, $8}' | sort -t: -k2 -n
  exit 0
fi

PORT="$1"

if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
  echo "Error: '$PORT' is not a valid port number (1–65535)"
  exit 1
fi

PIDS=$(lsof -ti :"$PORT" 2>/dev/null || true)

if [ -z "$PIDS" ]; then
  echo "Nothing running on port $PORT"
  exit 0
fi

echo "Port $PORT is in use:"
echo ""

while IFS= read -r pid; do
  info=$(ps -p "$pid" -o pid=,user=,comm=,command= 2>/dev/null || true)
  if [ -n "$info" ]; then
    pid_col=$(echo "$info"   | awk '{print $1}')
    user_col=$(echo "$info"  | awk '{print $2}')
    name_col=$(echo "$info"  | awk '{print $3}')
    cmd_col=$(echo "$info"   | awk '{$1=$2=$3=""; sub(/^ +/, ""); print}')
    printf "  PID:     %s\n"  "$pid_col"
    printf "  User:    %s\n"  "$user_col"
    printf "  Name:    %s\n"  "$name_col"
    printf "  Command: %s\n"  "$cmd_col"
    echo ""
  fi
done <<< "$PIDS"

echo "$PIDS" | xargs kill -9
echo "Killed."
