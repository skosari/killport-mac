#!/usr/bin/env bash

set -euo pipefail

VERSION="1.3.0"
REPO="skosari/killport-mac"
RAW="https://raw.githubusercontent.com/${REPO}/main"
ANCHOR_FILE="/etc/pf.anchors/killport"

check_update() {
  local remote
  remote=$(curl -fsSL --max-time 2 "${RAW}/VERSION" 2>/dev/null | tr -d '[:space:]' || true)
  if [ -n "$remote" ] && [ "$remote" != "$VERSION" ]; then
    echo "  Update available: $VERSION → $remote  (run: killport update)"
    echo ""
  fi
}

list_ports() {
  echo "Listening ports:"
  echo ""
  lsof -iTCP -iUDP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {printf "  %-8s %-10s %-10s %s\n", $9, $1, $2, $8}' | sort -t: -k2 -n
}

open_port() {
  local PORT=$1
  echo "Opening port $PORT to external connections..."
  if [ ! -f "$ANCHOR_FILE" ]; then sudo touch "$ANCHOR_FILE"; fi
  if sudo grep -q "port $PORT$" "$ANCHOR_FILE" 2>/dev/null; then
    echo "Port $PORT is already open."
    exit 0
  fi
  printf "pass in proto tcp from any to any port %s\npass in proto udp from any to any port %s\n" "$PORT" "$PORT" \
    | sudo tee -a "$ANCHOR_FILE" > /dev/null
  if ! sudo grep -q 'anchor "killport"' /etc/pf.conf 2>/dev/null; then
    printf '\nanchor "killport"\nload anchor "killport" from "%s"\n' "$ANCHOR_FILE" \
      | sudo tee -a /etc/pf.conf > /dev/null
  fi
  sudo pfctl -f /etc/pf.conf 2>/dev/null
  sudo pfctl -e 2>/dev/null || true
  echo "Port $PORT is now open (TCP + UDP)."
}

close_port() {
  local PORT=$1
  echo "Closing port $PORT from external connections..."
  if [ ! -f "$ANCHOR_FILE" ] || ! sudo grep -q "port $PORT$" "$ANCHOR_FILE" 2>/dev/null; then
    echo "Port $PORT is not managed by killport."
    exit 0
  fi
  sudo sed -i '' "/port ${PORT}$/d" "$ANCHOR_FILE"
  sudo pfctl -f /etc/pf.conf 2>/dev/null
  echo "Port $PORT is now closed."
}

show_ip() {
  echo "Network Interfaces"
  echo "────────────────────────────────────"
  # Loop each interface
  while IFS= read -r iface; do
    local ipv4 ipv6 mac status
    ipv4=$(ifconfig "$iface" 2>/dev/null | awk '/inet /{print $2}' | head -1)
    ipv6=$(ifconfig "$iface" 2>/dev/null | awk '/inet6 /{print $2}' | grep -v '%' | head -1)
    mac=$(ifconfig "$iface" 2>/dev/null | awk '/ether /{print $2}' | head -1)
    status=$(ifconfig "$iface" 2>/dev/null | awk '/status:/{print $2}' | head -1)
    [ -z "$ipv4" ] && [ -z "$mac" ] && continue
    echo ""
    echo "  Interface: $iface"
    [ -n "$mac" ]    && echo "  MAC:       $mac"
    [ -n "$ipv4" ]   && echo "  IPv4:      $ipv4"
    [ -n "$ipv6" ]   && echo "  IPv6:      $ipv6"
    [ -n "$status" ] && echo "  Status:    $status"
  done < <(ifconfig -l | tr ' ' '\n')

  echo ""
  echo "Default Gateway"
  echo "────────────────────────────────────"
  netstat -rn 2>/dev/null | awk '/^default/{print "  " $2; exit}'

  echo ""
  echo "DNS Servers"
  echo "────────────────────────────────────"
  scutil --dns 2>/dev/null | awk '/nameserver/{print "  " $3}' | sort -u

  echo ""
  echo "Firewall-managed ports (killport)"
  echo "────────────────────────────────────"
  if [ -f "$ANCHOR_FILE" ] && [ -s "$ANCHOR_FILE" ]; then
    grep -oE 'port [0-9]+' "$ANCHOR_FILE" | awk '{print "  " $2}' | sort -un
  else
    echo "  None"
  fi
}

# -------------------------------------------------------

if [ $# -eq 0 ]; then
  echo "killport v${VERSION}"
  echo ""
  echo "  killport                   show this help and list listening ports"
  echo "  killport <port>            kill whatever is running on that port"
  echo "  killport list              list all listening ports"
  echo "  killport open <port>       open a port to external connections"
  echo "  killport close <port>      close a port from external connections"
  echo "  killport ip                show IP addresses, DNS, and network info"
  echo "  killport update            update to the latest version"
  echo ""
  check_update
  list_ports
  exit 0
fi

case "$1" in

  update)
    echo "Checking for updates..."
    remote=$(curl -fsSL --max-time 5 "${RAW}/VERSION" 2>/dev/null | tr -d '[:space:]' || true)
    if [ -z "$remote" ]; then echo "Could not reach GitHub. Check your connection."; exit 1; fi
    if [ "$remote" = "$VERSION" ]; then echo "Already up to date (v${VERSION})"; exit 0; fi
    echo "Updating $VERSION → $remote..."
    INSTALL_PATH=$(command -v killport)
    if [ -w "$INSTALL_PATH" ]; then
      curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && chmod +x "$INSTALL_PATH"
    else
      sudo curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && sudo chmod +x "$INSTALL_PATH"
    fi
    echo "Updated to v${remote}. Run killport to confirm."
    ;;

  list)
    list_ports
    ;;

  ip)
    show_ip
    ;;

  open)
    [ -z "${2:-}" ] && { echo "Usage: killport open <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    open_port "$2"
    ;;

  close)
    [ -z "${2:-}" ] && { echo "Usage: killport close <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    close_port "$2"
    ;;

  *)
    PORT="$1"
    if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
      echo "Error: '$PORT' is not a valid port number (1–65535)"
      exit 1
    fi
    PIDS=$(lsof -ti :"$PORT" 2>/dev/null || true)
    if [ -z "$PIDS" ]; then echo "Nothing running on port $PORT"; exit 0; fi
    echo "Port $PORT is in use:"
    echo ""
    while IFS= read -r pid; do
      info=$(ps -p "$pid" -o pid=,user=,comm=,command= 2>/dev/null || true)
      if [ -n "$info" ]; then
        printf "  PID:     %s\n" "$(echo "$info" | awk '{print $1}')"
        printf "  User:    %s\n" "$(echo "$info" | awk '{print $2}')"
        printf "  Name:    %s\n" "$(echo "$info" | awk '{print $3}')"
        printf "  Command: %s\n" "$(echo "$info" | awk '{$1=$2=$3=""; sub(/^ +/, ""); print}')"
        echo ""
      fi
    done <<< "$PIDS"
    echo "$PIDS" | xargs kill -9
    echo "Killed."
    ;;

esac
