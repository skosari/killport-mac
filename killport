            with lock: errs+=1

def stat_loop():
    global peak
    SP=["⠋","⠙","⠹","⠸","⠼","⠴","⠦","⠧","⠇","⠏"]
    start=time.time(); prev=0; tick=0
    while not stop.is_set():
        elapsed=time.time()-start; rem=max(0,SECS-elapsed)
        with lock: s=sent; e=errs
        ps=s-prev; prev=s
        with lock:
            if ps>peak: peak=ps
        avg=s/max(elapsed,0.1)
        pct=min(100,int(elapsed/SECS*100)); bw=24
        bar="\u2588"*int(pct*bw/100)+"\u2591"*(bw-int(pct*bw/100))
        sys.stdout.write(
            f"\r  {D}{SP[tick%len(SP)]}  [{bar}]{R}  "
            f"{B}{s:,}{R} req  {avg:.0f}/s  {e} err  {D}{rem:.0f}s left{R}   ")
        sys.stdout.flush(); tick+=1; time.sleep(1)

ts=[threading.Thread(target=worker,daemon=True) for _ in range(THREADS)]
for t in ts: t.start()
threading.Thread(target=stat_loop,daemon=True).start()
time.sleep(SECS); stop.set(); time.sleep(0.5)
sys.stdout.write("\r"+" "*80+"\r"); sys.stdout.flush()

with lock: total=sent; total_err=errs; pk=peak
avg=total/max(SECS,1); ep=total_err*100//(total+total_err) if (total+total_err) else 0

still_up=False
try:
    cs=socket.socket(socket.AF_INET,socket.SOCK_STREAM)
    cs.settimeout(3); cs.connect((TARGET,PORT)); cs.close(); still_up=True
except: pass

sc=G if still_up else RE
st_txt="ONLINE — still responding" if still_up else "NOT RESPONDING — may be down"
now=datetime.datetime.now().strftime("%Y-%m-%d %H:%M")
sep="═"*54
report=(f"{sep}\n  STRESS TEST  ·  {TARGET}:{PORT}  ·  {now}\n{sep}\n"
        f"  Service:   {SVC}\n  Duration:  {SECS}s  ·  Threads: {THREADS}\n"
        f"  Requests:  {total:,}  ({avg:.0f}/s avg,  {pk}/s peak)\n"
        f"  Errors:    {total_err:,}  ({ep}%)\n"
        f"  After:     {st_txt}\n{sep}\n")

print(f"  {sep}"); print(f"  STRESS TEST COMPLETE"); print(f"  {sep}")
print(f"  Service:   {SVC}  ({TARGET}:{PORT})")
print(f"  Duration:  {SECS}s  ·  Threads: {THREADS}")
print(f"  Requests:  {B}{total:,}{R}  ({avg:.0f}/s avg  ·  {pk}/s peak)")
print(f"  Errors:    {total_err:,}  ({ep}%)")
print(f"  After:     {sc}{st_txt}{R}")
print(f"  {sep}")
with open(LOG,"a",encoding="utf-8") as f: f.write(report)
STRESSEOF

  python3 "$py_stress" "$ip" "$port" "$svc" "$DURATION" "$THREADS" "$ATTACK_LOG" || true
  trap - EXIT INT TERM
  [ -n "$_saved_stty" ] && stty "$_saved_stty" 2>/dev/null || stty sane 2>/dev/null || true
  rm -f "$py_stress" 2>/dev/null

  printf "\n${C}  ────────────────────────────────────────────${R}\n"
  printf "  ${D}Logged to: %s${R}\n\n" "$ATTACK_LOG"
}

stress_dispatch() {
  local sub="${1:-}"
  local C=$'\033[0;36m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  if [ -z "$sub" ]; then
    printf "\n${B}${C}  killport stress${R}  ${D}authorized connection flood testing${R}\n"
    printf "${C}  ────────────────────────────────────────────${R}\n\n"
    printf "  killport stress <ip:port>     flood test a single service\n\n"
    printf "  ${D}Examples:${R}\n"
    printf "    killport stress 192.168.1.10:80     HTTP flood\n"
    printf "    killport stress 192.168.1.10:22     TCP connection flood\n"
    printf "    killport stress 192.168.1.10:6379   Redis PING flood\n\n"
    printf "  ${D}Requires authorization. Only test systems you own or have permission to test.${R}\n\n"
    return 0
  fi
  stress_run "$sub"
}

# -------------------------------------------------------

if [ $# -eq 0 ]; then
  banner
  _remote=$(fetch_remote_version 2)
  _CY=$'\033[0;33m' _CR=$'\033[0m' _CD=$'\033[2m'
  if [ -n "$_remote" ] && [ "$_remote" != "$VERSION" ]; then
    echo "  v${VERSION}  ${_CY}→  v${_remote} available${_CR}  ${_CD}(run: killport update)${_CR}"
  else
    echo "  v${VERSION}"
  fi
  echo ""
  echo "  killport                   show this help and list listening ports"
  echo "  killport <port>            kill whatever is running on that port"
  echo "  killport list              list all listening ports"
  echo "  killport open <port>       open a port to external connections"
  echo "  killport close <port>      close a port from external connections"
  echo "  killport openports         show all ports open to external access"
  echo "  killport closedports       show all listening ports with no external access"
  echo "  killport ports             inspect all ports with firewall status"
  echo "  killport opencheck <ip>    probe an IP from this machine to check open ports"
  echo "  killport status <port>     show if a port is open or closed"
  echo "  killport ip                show IP addresses, DNS, and network info"
  echo "  killport attack <ip>       AI pentest: scan all ports + analysis"
  echo "  killport attack <ip>:port  AI pentest: scan single port + analysis"
  echo "  killport attack config     configure Ollama host and model"
  echo "  killport attack log        view attack history"
  echo "  killport stress <ip:port>  authorized connection flood / stress test"
  echo "  killport update            update to the latest version"
  echo "  killport uninstall         remove killport and all firewall rules"
  echo ""
  exit 0
fi

case "$1" in

  attack)
    attack_dispatch "${2:-}"
    ;;

  stress)
    stress_dispatch "${2:-}"
    ;;

  uninstall)
    echo "Uninstalling killport..."
    INSTALL_PATH=$(command -v killport)
    if [ -f "$INSTALL_PATH" ]; then
      sudo rm "$INSTALL_PATH"
      echo "  Removed $INSTALL_PATH"
    fi
    if [ -f /etc/pf.anchors/killport ]; then
      sudo rm /etc/pf.anchors/killport
      echo "  Removed /etc/pf.anchors/killport"
    fi
    if sudo grep -q 'killport' /etc/pf.conf 2>/dev/null; then
      sudo sed -i '' '/anchor "killport"/d' /etc/pf.conf
      sudo sed -i '' '/load anchor "killport"/d' /etc/pf.conf
      sudo pfctl -f /etc/pf.conf 2>/dev/null || true
      echo "  Cleaned pf.conf"
    fi
    echo "killport uninstalled."
    ;;

  update)
    echo "Checking for updates..."
    remote=$(fetch_remote_version 5)
    if [ -z "$remote" ]; then echo "Could not reach GitHub. Check your connection."; exit 1; fi
    if [ "$remote" = "$VERSION" ]; then echo "Already up to date (v${VERSION})"; exit 0; fi
    echo "Updating $VERSION → $remote..."
    INSTALL_PATH=$(command -v killport)
    if [ -w "$INSTALL_PATH" ]; then
      curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && chmod +x "$INSTALL_PATH"
    else
      sudo curl -fsSL "${RAW}/killport" -o "$INSTALL_PATH" && sudo chmod +x "$INSTALL_PATH"
    fi
    echo "Updated to v${remote}. Run killport to confirm."
    ;;

  list)
    list_ports
    ;;

  openports)
    open_ports
    ;;

  closedports)
    closed_ports
    ;;

  ports)
    ports_inspect
    ;;

  opencheck)
    [ -z "${2:-}" ] && { echo "Usage: killport opencheck <ip>"; exit 1; }
    opencheck_ports "$2"
    ;;

  status)
    [ -z "${2:-}" ] && { echo "Usage: killport status <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    status_port "$2"
    ;;

  ip)
    show_ip
    ;;

  open)
    [ -z "${2:-}" ] && { echo "Usage: killport open <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    open_port "$2"
    ;;

  close)
    [ -z "${2:-}" ] && { echo "Usage: killport close <port>"; exit 1; }
    [[ "$2" =~ ^[0-9]+$ ]] && [ "$2" -ge 1 ] && [ "$2" -le 65535 ] || { echo "Error: '$2' is not a valid port number (1–65535)"; exit 1; }
    close_port "$2"
    ;;

  *)
    PORT="$1"
    if ! [[ "$PORT" =~ ^[0-9]+$ ]] || [ "$PORT" -lt 1 ] || [ "$PORT" -gt 65535 ]; then
      echo "Error: '$PORT' is not a valid port number (1–65535)"
      exit 1
    fi
    PIDS=$(lsof -ti :"$PORT" 2>/dev/null || true)
    if [ -z "$PIDS" ]; then echo "Nothing running on port $PORT"; exit 0; fi
    echo "Port $PORT is in use:"
    echo ""
    while IFS= read -r pid; do
      info=$(ps -p "$pid" -o pid=,user=,comm=,command= 2>/dev/null || true)
      if [ -n "$info" ]; then
        printf "  PID:     %s\n" "$(echo "$info" | awk '{print $1}')"
        printf "  User:    %s\n" "$(echo "$info" | awk '{print $2}')"
        printf "  Name:    %s\n" "$(echo "$info" | awk '{print $3}')"
        printf "  Command: %s\n" "$(echo "$info" | awk '{$1=$2=$3=""; sub(/^ +/, ""); print}')"
        echo ""
      fi
    done <<< "$PIDS"
    echo "$PIDS" | xargs kill -9
    echo "Killed."
    ;;

esac
