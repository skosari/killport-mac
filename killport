# ── audit ────────────────────────────────────────────────

audit_firewall() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  printf "\n${B}${C}  killport audit${R}  ${D}firewall rule review${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local rules=""
  printf "  ${D}Loading firewall rules...${R}"
  rules=$(sudo -p $'\n  Password: ' pfctl -sr 2>/dev/null || sudo -p $'\n  Password: ' pfctl -s rules 2>/dev/null || true)
  if [ -z "$rules" ]; then
    printf "\r  ${Y}No rules found — try: sudo killport audit${R}\n\n"; return 0
  fi
  local total; total=$(echo "$rules" | grep -c . || true)
  printf "\r  ${D}%d rules loaded.%20s${R}\n" "$total" ""

  # Check if a port is currently listening (bash 3.2 compatible — no assoc arrays)
  _kp_listening() { netstat -an 2>/dev/null | grep -qE "[.:]${1}[[:space:]].*LISTEN"; }

  # Return service name for a danger port
  _kp_svcname() {
    case "$1" in
      21) echo "FTP" ;; 22) echo "SSH" ;; 23) echo "Telnet" ;; 25) echo "SMTP" ;;
      53) echo "DNS" ;; 445) echo "SMB" ;; 1433) echo "MSSQL" ;; 3306) echo "MySQL" ;;
      3389) echo "RDP" ;; 5432) echo "PostgreSQL" ;; 5900) echo "VNC" ;;
      6379) echo "Redis" ;; 8080) echo "HTTP-Alt" ;; 9200) echo "Elasticsearch" ;;
      11211) echo "Memcached" ;; 27017) echo "MongoDB" ;; *) echo "" ;;
    esac
  }

  local high_count=0 first_high=1 i=0
  local mediums=""  # newline-delimited: "port|remote|reason|rule"

  while IFS= read -r rule; do
    [ -z "$rule" ] && continue
    (( i++ )) || true
    printf "\r  ${D}Analysing %d / %d ...${R}   " "$i" "$total"

    # Skip pure block/drop rules
    echo "$rule" | grep -qiE "^block|^drop" && continue

    local is_high=0 is_medium=0 port_info="ALL PORTS" remote_info="Any IP" reason=""

    if echo "$rule" | grep -qiE "^pass" && ! echo "$rule" | grep -qiE "\bport\b"; then
      # No port restriction — catch-all pass
      is_high=1
      reason="Catch-all pass rule — allows ALL traffic from ANY source"
    else
      # Check each danger port
      local dp svc matched=0
      for dp in 21 22 23 25 53 445 1433 3306 3389 5432 5900 6379 8080 9200 11211 27017; do
        if echo "$rule" | grep -qiE "^pass" && echo "$rule" | grep -qE "\b${dp}\b" \
            && echo "$rule" | grep -qiE "from any|any to any"; then
          svc=$(_kp_svcname "$dp")
          port_info="$dp ($svc)"
          local live_note=""
          _kp_listening "$dp" && live_note=" — CURRENTLY LISTENING"
          reason="$svc open to any IP$live_note"
          if _kp_listening "$dp"; then is_high=1; else is_medium=1; fi
          matched=1; break
        fi
      done
    fi

    if [ "$is_high" -eq 1 ]; then
      printf "\r%-55s\r\n" ""
      if [ "$first_high" -eq 1 ]; then
        printf "\n  ${RE}── HIGH RISK ${R}\n\n"; first_high=0
      fi
      printf "  ${RE}✗  %.80s${R}\n" "$rule"
      printf "     ${D}%-18s${R} %s\n" "Port:" "$port_info"
      printf "     ${D}%-18s${R} %s\n" "Allowed from:" "$remote_info"
      printf "     ${Y}→ %s${R}\n\n" "$reason"
      (( high_count++ )) || true
    elif [ "$is_medium" -eq 1 ]; then
      mediums+="${port_info}|${remote_info}|${reason}|${rule}"$'\n'
    fi
  done <<< "$rules"

  [ "$high_count" -eq 0 ] && printf "\r  ${D}Analysed %d rules.%30s${R}\n" "$total" ""

  if [ -n "$mediums" ]; then
    local med_count; med_count=$(echo "$mediums" | grep -c . || true)
    printf "\n  ${Y}── MEDIUM RISK (%d rules) ${R}\n\n" "$med_count"
    while IFS='|' read -r p_ rem_ rsn_ rule_; do
      [ -z "$p_" ] && continue
      printf "  ${Y}⚠  %.80s${R}\n" "$rule_"
      printf "     ${D}%-18s${R} %s\n" "Port:" "$p_"
      printf "     ${D}%-18s${R} %s\n" "Allowed from:" "$rem_"
      printf "     ${D}→ %s${R}\n\n" "$rsn_"
    done <<< "$mediums"
  fi

  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local med_count=0
  [ -n "$mediums" ] && med_count=$(echo "$mediums" | grep -c . || true)
  local total_findings=$(( high_count + med_count ))
  if [ "$total_findings" -eq 0 ]; then
    printf "  ${G}✓  No significant issues detected across %d rules.${R}\n" "$total"
  else
    printf "  ${RE}%d high${R}  ·  ${Y}%d medium${R}  ·  %d rules OK\n" \
      "$high_count" "$med_count" "$(( i - total_findings ))"
    printf "  ${D}Run 'killport openports' to see which ports are reachable from outside.${R}\n"
  fi
  printf "\n"
}

# ── dns ──────────────────────────────────────────────────

dns_recon() {
  local domain="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  [ -z "$domain" ] && { printf "\n  ${Y}Usage: killport dns <domain>${R}\n\n"; return 1; }

  printf "\n${B}${C}  killport dns${R}  ${D}%s${R}\n" "$domain"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local has_dig=0; command -v dig &>/dev/null && has_dig=1

  _kp_dns_query() {
    local type="$1" tgt="$2"
    if [ "$has_dig" -eq 1 ]; then
      dig +short "$type" "$tgt" 2>/dev/null | grep -v "^$" || true
    else
      host -t "$type" "$tgt" 2>/dev/null | grep -v "NXDOMAIN\|not found\|no.*record" || true
    fi
  }

  _kp_show_recs() {
    local label="$1"; shift
    printf "  ${B}%-8s${R}" "$label"
    local first=1
    while IFS= read -r rec; do
      [ -z "$rec" ] && continue
      if [ "$first" -eq 1 ]; then printf "  ${D}%s${R}\n" "$rec"; first=0
      else printf "  ${D}%8s  %s${R}\n" "" "$rec"; fi
    done
    [ "$first" -eq 1 ] && printf "  ${D}(none)${R}\n" || true
  }

  _kp_dns_query A    "$domain" | _kp_show_recs "A"
  _kp_dns_query AAAA "$domain" | _kp_show_recs "AAAA"
  _kp_dns_query MX   "$domain" | _kp_show_recs "MX"
  _kp_dns_query NS   "$domain" | _kp_show_recs "NS"
  _kp_dns_query TXT  "$domain" | _kp_show_recs "TXT"

  # Reverse DNS for A records
  local a_list=()
  while IFS= read -r ip; do [ -n "$ip" ] && a_list+=("$ip"); done \
    < <(_kp_dns_query A "$domain")
  if [ "${#a_list[@]}" -gt 0 ]; then
    printf "  ${B}%-8s${R}\n" "REVERSE"
    for ip in "${a_list[@]}"; do
      local rev=""
      if [ "$has_dig" -eq 1 ]; then rev=$(dig +short -x "$ip" 2>/dev/null | head -1 || true)
      else rev=$(host "$ip" 2>/dev/null | awk '/domain name/{print $NF}' | head -1 || true); fi
      printf "    ${D}%s  →  %s${R}\n" "$ip" "${rev:-(no PTR)}"
    done
    printf "\n"
  fi

  # Zone transfer test
  printf "  ${B}%-8s${R}\n" "AXFR"
  local ns_list=() axfr_ok=0
  while IFS= read -r ns; do [ -n "$ns" ] && ns_list+=("$ns"); done \
    < <(_kp_dns_query NS "$domain")
  for ns in "${ns_list[@]:-}"; do
    [ -z "$ns" ] && continue
    ns="${ns%.}"
    local axfr_out=""
    if [ "$has_dig" -eq 1 ]; then
      axfr_out=$(dig AXFR "$domain" "@$ns" 2>/dev/null || true)
    else
      axfr_out=$(host -l "$domain" "$ns" 2>/dev/null || true)
    fi
    if [ -n "$axfr_out" ] && echo "$axfr_out" | grep -qE "\bSOA\b|[[:space:]]IN[[:space:]]" \
        && ! echo "$axfr_out" | grep -qE "Transfer failed|REFUSED|timed out|no servers"; then
      printf "    ${RE}⚠  ALLOWED from %s — misconfiguration!${R}\n" "$ns"; axfr_ok=1; fi
  done
  [ "$axfr_ok" -eq 0 ] && printf "    ${G}✓  Zone transfers blocked.${R}\n" || true
  printf "\n"
}

# ── forward ──────────────────────────────────────────────

forward_port() {
  local local_port="${1:-}" target="${2:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  if [ -z "$local_port" ] || [ -z "$target" ]; then
    printf "\n  ${Y}Usage: killport forward <local-port> <host:port>${R}\n"
    printf "  ${D}Example: killport forward 8080 192.168.1.10:80${R}\n\n"; return 1
  fi
  [[ "$target" == *:* ]] || { printf "\n  ${Y}Target must be host:port${R}\n\n"; return 1; }
  local t_host="${target%:*}" t_port="${target##*:}"

  printf "\n${B}${C}  killport forward${R}  ${D}localhost:%s  →  %s${R}\n" "$local_port" "$target"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local _stty; _stty=$(stty -g 2>/dev/null) || _stty=""
  trap '[ -n "$_stty" ] && stty "$_stty" 2>/dev/null || stty sane 2>/dev/null
        printf "\n  ${D}Forward stopped.${R}\n\n"; exit 0' INT TERM

  if command -v socat &>/dev/null; then
    printf "  ${G}✓${R}  ${D}socat${R}  —  forwarding port %s to %s\n" "$local_port" "$target"
    printf "  ${D}Press Ctrl+C to stop.${R}\n\n"
    socat "TCP-LISTEN:${local_port},fork,reuseaddr" "TCP:${t_host}:${t_port}"
  elif command -v nc &>/dev/null; then
    printf "  ${Y}socat not found — using nc (single connection at a time)${R}\n"
    printf "  ${D}Install socat for full support:  brew install socat${R}\n\n"
    printf "  ${D}Press Ctrl+C to stop.${R}\n\n"
    while true; do nc -l "$local_port" | nc "$t_host" "$t_port" || true; done
  else
    printf "  ${RE}Neither socat nor nc found.${R}\n"
    printf "  ${D}Install socat:  brew install socat${R}\n\n"; return 1
  fi
}

# ── fix ──────────────────────────────────────────────────

fix_run() {
  local target="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  if [ -z "$target" ] || [[ "$target" != *:* ]]; then
    printf "\n  ${Y}Usage: killport fix <ip:port>${R}\n\n"; return 1
  fi
  local ip="${target%:*}" port="${target##*:}"

  command -v nmap &>/dev/null || { printf "\n  ${Y}nmap required:  brew install nmap${R}\n\n"; return 1; }

  printf "\n${B}${C}  killport fix${R}  ${D}%s${R}\n" "$target"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  ${D}Detecting service on port %s...${R}\n\n" "$port"

  local nmap_out svc ver svc_line
  nmap_out=$(nmap -sV -p "$port" --open -T4 "$ip" 2>/dev/null)
  svc_line=$(grep "${port}/tcp" <<< "$nmap_out" | head -1 || true)
  svc=$(awk '{print $3}' <<< "$svc_line" || true)
  ver=$(awk '{$1=$2=$3=""; print $0}' <<< "$svc_line" | sed 's/^ *//' || true)

  if [ -z "$svc" ] || [ "$svc" = "open" ] || [ "$svc" = "filtered" ]; then
    printf "  ${Y}Could not detect service on %s:%s${R}\n\n" "$ip" "$port"; return 1
  fi

  printf "  ${B}Service:${R}  %s\n" "$svc"
  printf "  ${B}Version:${R}  ${D}%s${R}\n\n" "${ver:-unknown}"

  # Detect if target is this machine
  local _is_local=0
  [[ "$ip" == "127."* || "$ip" == "::1" || "$ip" == "localhost" ]] && _is_local=1
  if [ "$_is_local" -eq 0 ]; then
    while IFS= read -r _own; do
      [ "$_own" = "$ip" ] && _is_local=1 && break
    done < <(ifconfig 2>/dev/null | awk '/inet /{gsub("addr:","",$2); print $2}')
  fi

  if [ "$_is_local" -eq 1 ]; then
    printf "  ${G}✓  Target is this machine — can apply fixes directly.${R}\n\n"
  else
    printf "  ${D}Remote target — will generate a fix script to copy over.${R}\n\n"
  fi

  attack_load_conf
  local _ollama="${ATTACK_OLLAMA:-localhost:11434}"
  local _model="${ATTACK_MODEL:-}"

  local _py _script
  _py=$(mktemp "${TMPDIR:-/tmp}/kp_fix.XXXXXX")
  _script=$(mktemp "${TMPDIR:-/tmp}/kp_fix_apply.XXXXXX")

  local _saved_stty; _saved_stty=$(stty -g 2>/dev/null) || _saved_stty=""
  trap 'rm -f "${_py:-}" "${_script:-}" 2>/dev/null; stty sane 2>/dev/null || true' EXIT INT TERM

  cat > "$_py" << 'FIXPYEOF'
import sys,json,subprocess,os,re,datetime,platform
try: import urllib.request,urllib.parse; HAS_NET=True
except: HAS_NET=False

IP=sys.argv[1]; PORT=sys.argv[2]; SVC=sys.argv[3]; VER=sys.argv[4]
IS_LOCAL=sys.argv[5]=="1"; OLLAMA=sys.argv[6]; MODEL=sys.argv[7]; SCRIPT_OUT=sys.argv[8]
OS_=platform.system()  # Darwin or Linux

B="\033[1m"; C="\033[0;36m"; D="\033[2m"; G="\033[0;32m"
Y="\033[0;33m"; RE="\033[0;31m"; R="\033[0m"
SC={"CRITICAL":RE,"HIGH":RE,"MEDIUM":Y,"LOW":G,"NONE":D}

# ── Query NVD ────────────────────────────────────────────────
cvelist=[]
if HAS_NET:
    try:
        print(f"  {D}Querying NVD database...{R}",flush=True)
        kw=f"{SVC} {VER.split()[0]}" if VER else SVC
        query=urllib.parse.quote(kw)
        url=f"https://services.nvd.nist.gov/rest/json/cves/2.0?keywordSearch={query}&resultsPerPage=5"
        req=urllib.request.Request(url,headers={"User-Agent":"killport/1.0"})
        with urllib.request.urlopen(req,timeout=12) as r: obj=json.loads(r.read())
        vulns=obj.get("vulnerabilities",[]); total=obj.get("totalResults",len(vulns))
        if vulns:
            print(f"\n  {B}{total}{R} CVE(s) — top {len(vulns)} shown:\n")
            for v in vulns:
                c=v.get("cve",{})
                cid=c.get("id","?")
                desc=next((d["value"] for d in c.get("descriptions",[]) if d.get("lang")=="en"),"")[:100]
                sev,score="UNKNOWN",""
                for mk in ("cvssMetricV31","cvssMetricV30","cvssMetricV2"):
                    if mk in c.get("metrics",{}):
                        m0=c["metrics"][mk][0]; cd=m0.get("cvssData",{})
                        sev=cd.get("baseSeverity",m0.get("baseSeverity","?")); score=str(cd.get("baseScore",""))
                        break
                sc=SC.get(sev.upper(),D)
                print(f"  {B}{cid}{R}  {sc}[{sev}  {score}]{R}")
                print(f"  {D}{desc}{'...' if len(desc)==100 else ''}{R}\n")
                cvelist.append(f"{cid} [{sev} {score}]: {desc}")
    except Exception as e:
        print(f"  {Y}NVD unavailable: {e}{R}\n")

# ── Generate fix script ──────────────────────────────────────
