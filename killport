            except: pass
        proc.wait()
        sys.stdout.write("\r"+" "*80+"\r\n"); sys.stdout.flush()
        full=re.sub(r'<think>.*?</think>','',full,flags=re.DOTALL)
        full=re.sub(r'^.*?</think>\s*','',full,flags=re.DOTALL)
        full=re.sub(r'<think>.*','',full,flags=re.DOTALL)
        # Strip markdown code fences
        full=re.sub(r'```\w*','',full)
        # Strip any preamble before the first section header
        m=re.search(r'^(UPGRADE|CONFIG|NETWORK)[:\s]',full,re.MULTILINE|re.IGNORECASE)
        if m: full=full[m.start():]
        # Strip trailing prose after last command/config line
        lines=full.splitlines()
        last_cmd=0
        for i,l in enumerate(lines):
            s=l.strip()
            if s and (s.startswith('#') or re.match(r'^(UPGRADE|CONFIG|NETWORK)[:\s]',s,re.I)
                      or any(w in s for w in ('sudo','apt','yum','brew','systemctl','service ','iptables','ufw','pfctl','=','Protocol','Permit','Allow','Deny','Max','Client','Log','Cipher','Port ','ssh','sshd'))):
                last_cmd=i
        full='\n'.join(lines[:last_cmd+1]).strip()
        if full:
            for line in full.splitlines():
                l=line.rstrip()
                if re.match(r'^(UPGRADE|CONFIG|NETWORK)[:\s]',l,re.I):
                    print(f"\n  {B}{C}{l}{R}")
                elif l.startswith("  ") or l.startswith("\t"):
                    print(f"  {D}{l}{R}")
                elif l:
                    print(f"  {l}")
        else:
            print(f"  {D}(no AI response — is Ollama running?){R}")
    except Exception as e:
        print(f"  {D}AI unavailable: {e}{R}")
else:
    print(f"  {D}No model configured — run: killport config{R}")

print(f"\n{C}  ────────────────────────────────────────────{R}")
FIXPYEOF

  python3 "$_py" "$ip" "$port" "$svc" "$ver" "$_is_local" \
    "$_ollama" "${_model:-}" "$_script" 2>/dev/null || true

  trap - EXIT INT TERM
  rm -f "$_py" 2>/dev/null
  [ -n "$_saved_stty" ] && stty "$_saved_stty" 2>/dev/null || stty sane 2>/dev/null || true

  if [ ! -s "$_script" ]; then printf "  ${Y}Fix script generation failed.${R}\n\n"; return 1; fi

  if [ "$_is_local" -eq 1 ]; then
    printf "  Apply these fixes now? ${Y}(requires sudo)${R}  [yes/N]: "
    local _ans=""; IFS= read -r _ans; _ans="${_ans%$'\r'}"
    if [[ "$_ans" == "yes" ]]; then
      printf "\n${C}  ────────────────────────────────────────────${R}\n\n"
      sudo bash "$_script"
      printf "\n${C}  ────────────────────────────────────────────${R}\n"
      printf "  ${G}✓  Fixes applied.${R}  ${D}Verify with: killport vuln %s${R}\n\n" "$target"
    else
      printf "\n  ${D}Fix script saved to:${R}  %s\n" "$_script"
      printf "  ${D}Run manually:       ${R}  sudo bash %s\n\n" "$_script"
    fi
  else
    printf "  ${D}Fix script saved to:${R}  %s\n\n" "$_script"
    printf "  ${D}Copy and apply on remote machine:${R}\n"
    printf "  ${B}scp %s %s@%s:/tmp/fix.sh${R}\n" "$_script" '${USER}' "$ip"
    printf "  ${B}ssh %s@%s 'sudo bash /tmp/fix.sh'${R}\n\n" '${USER}' "$ip"
  fi
}

fix_dispatch() {
  local sub="${1:-}"
  local C=$'\033[0;36m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  if [ -z "$sub" ]; then
    printf "\n${B}${C}  killport fix${R}  ${D}detect and fix service vulnerabilities${R}\n"
    printf "${C}  ────────────────────────────────────────────${R}\n\n"
    printf "  killport fix <ip:port>     detect vulnerabilities and generate a fix  (requires Ollama)\n\n"
    printf "  ${D}Examples:${R}\n"
    printf "    killport fix 192.168.1.10:22     harden SSH\n"
    printf "    killport fix 192.168.1.10:6379   harden Redis\n"
    printf "    killport fix 127.0.0.1:3306      harden MySQL locally\n\n"
    printf "  ${D}Supports: SSH, Redis, MySQL, PostgreSQL, MongoDB, HTTP/Nginx/Apache,\n"
    printf "            FTP, Telnet, Memcached${R}\n\n"
    return 0
  fi
  fix_run "$sub"
}

# ── Wake on LAN ──────────────────────────────────────────────
WOL_HOSTS="${HOME}/.config/killport/wol_hosts"

wol_send() {
  local mac="$1" ip="${2:-255.255.255.255}"
  mac=$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]' | tr '-' ':')
  if ! [[ "$mac" =~ ^([0-9a-f]{2}:){5}[0-9a-f]{2}$ ]]; then
    printf "  Invalid MAC address: %s\n" "$mac"; return 1
  fi
  python3 - "$mac" "$ip" <<'PYEOF'
import sys, socket
mac = sys.argv[1]
ip  = sys.argv[2] if len(sys.argv) > 2 and sys.argv[2] != '255.255.255.255' else '<broadcast>'
mac_bytes = bytes.fromhex(mac.replace(':',''))
magic = b'\xff'*6 + mac_bytes*16
with socket.socket(socket.AF_INET, socket.SOCK_DGRAM) as s:
    s.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    s.sendto(magic, ('<broadcast>', 9))
    if ip != '<broadcast>':
        s.sendto(magic, (ip, 9))
print("ok")
PYEOF
}

wol_load_hosts() {
  WOL_SAVED=()
  [ -f "$WOL_HOSTS" ] || return 0
  while IFS= read -r line; do
    [[ -z "$line" || "$line" =~ ^# ]] && continue
    WOL_SAVED+=("$line")
  done < "$WOL_HOSTS"
}

wol_save_host() {
  local name="$1" mac="$2" ip="${3:-}"
  mac=$(printf '%s' "$mac" | tr '[:upper:]' '[:lower:]' | tr '-' ':')
  if ! [[ "$mac" =~ ^([0-9a-f]{2}:){5}[0-9a-f]{2}$ ]]; then
    printf "  Invalid MAC: %s\n" "$mac"; return 1
  fi
  mkdir -p "${HOME}/.config/killport"
  local tmp=""
  [ -f "$WOL_HOSTS" ] && tmp=$(grep -v "^${name} " "$WOL_HOSTS" 2>/dev/null || true)
  printf '%s\n' "$tmp" > "$WOL_HOSTS"
  printf '%s %s %s\n' "$name" "$mac" "$ip" >> "$WOL_HOSTS"
}

# ── Network Host Discovery (shared by scan + wol) ────────
_NET_PIDS=()
NET_SCAN_BASE=""
NET_SCAN_HOSTS=()  # "hostname ip mac" per entry

_net_detect_base() {
  local iface
  iface=$(route -n get default 2>/dev/null | awk '/interface:/{print $2}' | head -1)
  [ -z "$iface" ] && iface=$(ifconfig -l 2>/dev/null | tr ' ' '\n' | grep -vE '^(lo|utun|awdl|llw|bridge|gif|stf)' | head -1)
  local myip
  myip=$(ipconfig getifaddr "$iface" 2>/dev/null || ifconfig "$iface" 2>/dev/null | awk '/inet /{print $2}' | head -1)
  [ -z "$myip" ] && return 1
  NET_SCAN_BASE=$(printf '%s' "$myip" | cut -d. -f1-3)
}

_mac_norm() {
  local raw=$1 a b c d e f
  IFS=: read -r a b c d e f <<< "$raw"
  printf '%02x:%02x:%02x:%02x:%02x:%02x' \
    $(( 16#$a )) $(( 16#$b )) $(( 16#$c )) \
    $(( 16#$d )) $(( 16#$e )) $(( 16#$f ))
}

_net_progress_bar() {
  local done=$1 total=$2 found=$3
  [ "$total" -eq 0 ] && return
  local C=$'\033[0;36m' D=$'\033[2m' R=$'\033[0m'
  local pct=$(( done * 100 / total ))
  local filled=$(( done * 30 / total ))
  local empty=$(( 30 - filled ))
  local bar="" i=0
  while [ "$i" -lt "$filled" ]; do bar+="█"; i=$(( i + 1 )); done
  i=0
  while [ "$i" -lt "$empty" ]; do bar+="░"; i=$(( i + 1 )); done
  printf "\r  ${C}[%s]${R}  ${D}%3d%%  %d host(s) found${R}   " \
    "$bar" "$pct" "$found"
}

net_scan_hosts() {
  # Scans local /24. Prints progress bar + hosts as found.
  # Populates NET_SCAN_HOSTS. Accepts optional list of IPs to skip.
  # Subshells only ping (triggers ARP) and mark done. Main loop does arp -n
  # per completed ping — gives ARP cache time to settle, catches ICMP-blocked hosts.
  local G=$'\033[0;32m' D=$'\033[2m' R=$'\033[0m' Y=$'\033[0;33m'

  _net_detect_base || {
    printf "  ${Y}Could not determine local subnet.${R}\n\n"
    NET_SCAN_HOSTS=(); return 1
  }
  NET_SCAN_HOSTS=()
  _NET_PIDS=()

  local _tmpdir
  _tmpdir=$(mktemp -d)
  mkdir "$_tmpdir/done" "$_tmpdir/proc"
  local _total=254

  for i in $(seq 1 254); do
    ( ping -c1 -W500 "${NET_SCAN_BASE}.${i}" &>/dev/null || true
      touch "$_tmpdir/done/$i" ) &
  done

  local -a _shown=("$@")
  local _found=0 _total_done=0 _f _i _ip _mac _arp_line

  _net_progress_bar 0 "$_total" 0

  while true; do
    # Move each completed ping into proc/ and check its ARP entry
    for _f in "$_tmpdir/done/"*; do
      [ -f "$_f" ] || continue
      mv "$_f" "$_tmpdir/proc/" 2>/dev/null || continue
      _total_done=$(( _total_done + 1 ))
      _i=$(basename "$_f")
      _ip="${NET_SCAN_BASE}.${_i}"

      _skip=0
      for _sm in "${_shown[@]+"${_shown[@]}"}"; do [ "$_sm" = "$_ip" ] && _skip=1; done
      [ "$_skip" -eq 1 ] && continue

      # ARP entry present = host is up (works even if ICMP blocked, e.g. Windows)
      _arp_line=$(arp -n "$_ip" 2>/dev/null || true)
      _mac=$(printf '%s' "$_arp_line" | grep -oE '([0-9a-f]{1,2}:){5}[0-9a-f]{1,2}' | head -1 || true)
      [ -z "$_mac" ] && continue

      _mac=$(_mac_norm "$_mac")
      (( _found++ )) || true
      _shown+=("$_ip")
      NET_SCAN_HOSTS+=("? ${_ip} ${_mac}")
      printf "\r\033[2K  ${G}%-30s${R}  %-15s  ${D}%s${R}\n" "?" "$_ip" "$_mac"
      _net_progress_bar "$_total_done" "$_total" "$_found"
    done

    _net_progress_bar "$_total_done" "$_total" "$_found"
    [ "$_total_done" -ge "$_total" ] && break
    sleep 0.1
  done

  wait 2>/dev/null || true
  rm -rf "$_tmpdir" 2>/dev/null || true
  printf "\r\033[2K"
}

wol_dispatch() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  local subcmd="${1:-}"

  case "$subcmd" in
    save)
      local name="${2:-}" mac="${3:-}" ip="${4:-}"
      [ -z "$name" ] || [ -z "$mac" ] && { printf "  Usage:  save <name> <mac> [ip]\n"; exit 1; }
      wol_save_host "$name" "$mac" "$ip" && printf "  ${G}Saved:${R} %s  %s\n\n" "$name" "$mac"
      ;;
    delete|remove)
      local name="${2:-}"
      [ -z "$name" ] && { printf "  Usage:  delete <name>\n"; exit 1; }
      if [ -f "$WOL_HOSTS" ]; then
        local tmp; tmp=$(grep -v "^${name} " "$WOL_HOSTS" 2>/dev/null || true)
        printf '%s\n' "$tmp" > "$WOL_HOSTS"
        printf "  ${G}Removed:${R} %s\n\n" "$name"
      else
        printf "  ${Y}No saved hosts file found.${R}\n\n"
      fi
      ;;
    list)
      wol_load_hosts
      printf "\n${B}${C}  Saved WoL Hosts${R}\n"
      printf "${C}  ────────────────────────────────────────────${R}\n\n"
      if [ "${#WOL_SAVED[@]}" -eq 0 ]; then
        printf "  ${D}None. Use ' save <name> <mac> [ip]' to add one.${R}\n\n"
        return
      fi
      for entry in "${WOL_SAVED[@]+"${WOL_SAVED[@]}"}"; do
        local n m i
        n=$(printf '%s' "$entry" | awk '{print $1}')
        m=$(printf '%s' "$entry" | awk '{print $2}')
        i=$(printf '%s' "$entry" | awk '{print $3}')
        printf "  ${G}★${R}  ${B}%-20s${R}  %s  ${D}%s${R}\n" "$n" "$m" "$i"
      done
      printf "\n"
      ;;
    ""|scan)
      stty sane 2>/dev/null || true
      printf "\n${B}${C}  Wake on LAN${R}\n"
      printf "${C}  ────────────────────────────────────────────${R}\n\n"

      wol_load_hosts

      # Build entries list: saved hosts first (print immediately, numbered)
      local -a _entries=() _skip_macs=()
      local _count=0

      for entry in "${WOL_SAVED[@]+"${WOL_SAVED[@]}"}"; do
        local sn sm si
        sn=$(printf '%s' "$entry" | awk '{print $1}')
        sm=$(printf '%s' "$entry" | awk '{print $2}')
        si=$(printf '%s' "$entry" | awk '{print $3}')
        (( _count++ )) || true
        _entries+=("$sm|$si|$sn")
        _skip_macs+=("$sm")
        printf "  ${B}%2d${R}  ${G}★${R} ${B}%-22s${R}  %s  ${D}%s${R}\n" "$_count" "$sn" "$sm" "$si"
      done
      [ "${#WOL_SAVED[@]}" -gt 0 ] && printf "\n"

      # Scan using same temp-file + arp -n approach as net_scan_hosts
      _net_detect_base || { printf "  ${Y}Could not determine local subnet.${R}\n\n"; return; }
      printf "  ${D}Scanning %s — type a number + Enter to wake immediately${R}\n\n" "$NET_SCAN_BASE"

      local _tmpdir
      _tmpdir=$(mktemp -d)
      mkdir "$_tmpdir/done" "$_tmpdir/proc"
      local _total=254
      NET_SCAN_HOSTS=()

      for i in $(seq 1 254); do
        ( ping -c1 -W500 "${NET_SCAN_BASE}.${i}" &>/dev/null || true
          touch "$_tmpdir/done/$i" ) &
      done

      local _found=0 _total_done=0 _f _i _ip _mac _arp_line _early=""

      _net_progress_bar 0 "$_total" "$_count"

      while true; do
        for _f in "$_tmpdir/done/"*; do
          [ -f "$_f" ] || continue
          mv "$_f" "$_tmpdir/proc/" 2>/dev/null || continue
          _total_done=$(( _total_done + 1 ))
          _i=$(basename "$_f")
          _ip="${NET_SCAN_BASE}.${_i}"

          _skip=0
          for _sm in "${_skip_macs[@]+"${_skip_macs[@]}"}"; do [ "$_sm" = "$_ip" ] && _skip=1; done
          [ "$_skip" -eq 1 ] && continue

          _arp_line=$(arp -n "$_ip" 2>/dev/null || true)
          _mac=$(printf '%s' "$_arp_line" | grep -oE '([0-9a-f]{1,2}:){5}[0-9a-f]{1,2}' | head -1 || true)
          [ -z "$_mac" ] && continue

          _mac=$(_mac_norm "$_mac")
          (( _count++ )) || true; (( _found++ )) || true
          _skip_macs+=("$_ip")
          _entries+=("$_mac|$_ip|?")
          NET_SCAN_HOSTS+=("? ${_ip} ${_mac}")
          printf "\r\033[2K  ${B}%2d${R}  %-30s  %-15s  ${D}%s${R}\n" "$_count" "?" "$_ip" "$_mac"
          _net_progress_bar "$_total_done" "$_total" "$_count"
        done

        _net_progress_bar "$_total_done" "$_total" "$_count"

        if read -r -t 0 2>/dev/null; then
          IFS= read -r _early 2>/dev/null || true
          _early=$(printf '%s' "$_early" | tr -d '[:space:]')
          if [[ "$_early" =~ ^[0-9]+$ ]] && [ "$_early" -ge 1 ] && [ "$_early" -le "$_count" ]; then
            printf "\r\033[2K"
            break
          fi
          _early=""
        fi

        [ "$_total_done" -ge "$_total" ] && break
        sleep 0.1
      done

      wait 2>/dev/null || true
      rm -rf "$_tmpdir" 2>/dev/null || true
      printf "\r\033[2K"

      if [ "${#_entries[@]}" -eq 0 ]; then
        printf "  ${Y}No hosts found.${R}\n\n"
        printf "  ${D}Add a known host:   save <name> <mac> [ip]${R}\n\n"
        return
      fi

      local _sel
      if [ -n "$_early" ]; then
        _sel="$_early"
      else
        printf "\n  ${D}Enter number to wake, or 's <num> <name>' to save a host:${R}\n  → "
        read -r _sel; _sel="${_sel%$'\r'}"
      fi

      if [[ "$_sel" =~ ^s[[:space:]]+([0-9]+)[[:space:]]+(.+)$ ]]; then
        local s_idx="${BASH_REMATCH[1]}" s_name="${BASH_REMATCH[2]}"
        if [ "$s_idx" -ge 1 ] && [ "$s_idx" -le "${#_entries[@]}" ]; then
          local e="${_entries[$(( s_idx - 1 ))]}"
          local e_mac="${e%%|*}" e_rest="${e#*|}" e_ip="${e_rest%%|*}"
          wol_save_host "$s_name" "$e_mac" "$e_ip"
          printf "  ${G}Saved as '%s'. Waking now...${R}\n" "$s_name"
          _sel="$s_idx"
        else
          printf "  ${Y}Invalid number.${R}\n\n"; return
        fi
      fi

      if [[ "$_sel" =~ ^[0-9]+$ ]] && [ "$_sel" -ge 1 ] && [ "$_sel" -le "${#_entries[@]}" ]; then
        local e="${_entries[$(( _sel - 1 ))]}"
        local e_mac="${e%%|*}" e_rest="${e#*|}" e_ip="${e_rest%%|*}" e_name="${e_rest#*|}"
        printf "\n  Waking ${B}%s${R}  ${D}%s${R}  %s\n" "$e_name" "$e_mac" "$e_ip"
        if wol_send "$e_mac" "$e_ip" 2>/dev/null | grep -q ok; then
          printf "  ${G}Magic packet sent.${R}\n\n"
        else
          printf "  ${RE}Failed to send magic packet (is python3 installed?).${R}\n\n"
        fi
      else
        printf "  ${D}Cancelled.${R}\n\n"
      fi
      ;;
    *)
      wol_load_hosts
      local found_mac="" found_ip=""
      for entry in "${WOL_SAVED[@]+"${WOL_SAVED[@]}"}"; do
        local n m i
        n=$(printf '%s' "$entry" | awk '{print $1}')
        m=$(printf '%s' "$entry" | awk '{print $2}')
        i=$(printf '%s' "$entry" | awk '{print $3}')
        if [ "$n" = "$subcmd" ]; then found_mac="$m"; found_ip="$i"; fi
      done
      if [ -n "$found_mac" ]; then
        printf "\n  Waking ${B}%s${R}  ${D}%s${R}\n" "$subcmd" "$found_mac"
        if wol_send "$found_mac" "$found_ip" 2>/dev/null | grep -q ok; then
          printf "  ${G}Magic packet sent.${R}\n\n"
        else
          printf "  ${RE}Failed to send magic packet.${R}\n\n"
        fi
        return
      fi
      if [[ "$subcmd" =~ ^([0-9a-fA-F]{2}[:-]){5}[0-9a-fA-F]{2}$ ]]; then
        printf "\n  Waking ${B}%s${R}\n" "$subcmd"
        if wol_send "$subcmd" 2>/dev/null | grep -q ok; then
          printf "  ${G}Magic packet sent.${R}\n\n"
        else
          printf "  ${RE}Failed to send magic packet.${R}\n\n"
        fi
        return
      fi
      printf "  No saved host named '%s'.\n" "$subcmd"
      printf "  Usage:\n"
      printf "                  scan network + pick a host to wake\n"
      printf "     <name>       wake a saved host by name\n"
      printf "     <mac>        wake by MAC address directly\n"
      printf "    killport wol save <name> <mac> [ip]\n"
      printf "    killport wol delete <name>\n"
      printf "    killport wol list\n\n"
      exit 1
      ;;
  esac
}

ssh_dispatch() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  local token="${1:-}"

  local KP_DIR="$HOME/.killport"
  local KEY_FILE="$KP_DIR/id_ed25519"
  local PUB_FILE="$KP_DIR/id_ed25519.pub"

  # ── accept mode ──────────────────────────────────────────────────────────
  if [[ "$token" == ks:* ]]; then
    local raw="${token#ks:}"
    local json
    json=$(printf '%s' "$raw" | base64 -D 2>/dev/null) || {
      printf "\n  ${RE}Invalid token (base64 decode failed).${R}\n\n"; exit 1
    }

    local remote_user remote_ip remote_pubkey
    remote_user=$(printf '%s' "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['user'])" 2>/dev/null)
    remote_ip=$(printf '%s' "$json"   | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['ip'])"   2>/dev/null)
    remote_pubkey=$(printf '%s' "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d['pubkey'])" 2>/dev/null)

    if [ -z "$remote_pubkey" ]; then
      printf "\n  ${RE}Invalid token (could not parse — was it copied in full?).${R}\n\n"; exit 1
    fi

    mkdir -p "$HOME/.ssh"
    chmod 700 "$HOME/.ssh"
    touch "$HOME/.ssh/authorized_keys"
    chmod 600 "$HOME/.ssh/authorized_keys"

    if grep -qF "$remote_pubkey" "$HOME/.ssh/authorized_keys" 2>/dev/null; then
      printf "\n  ${Y}Key already present in ~/.ssh/authorized_keys — no change.${R}\n"
    else
      printf '\n%s\n' "$remote_pubkey" >> "$HOME/.ssh/authorized_keys"
      printf "\n  ${G}✓ Key added to ~/.ssh/authorized_keys${R}\n"
    fi

    printf "  ${D}From: %s@%s${R}\n\n" "$remote_user" "$remote_ip"

    local our_ip our_user
    our_user=$(whoami)
    our_ip=$(ipconfig getifaddr en0 2>/dev/null \
          || ipconfig getifaddr en1 2>/dev/null \
          || ipconfig getifaddr en2 2>/dev/null \
          || echo "<this-mac-ip>")

    # Advisory: check Remote Login without sudo (just inspect launchd)
    if ! launchctl list com.openssh.sshd &>/dev/null; then
      printf "  ${Y}⚠  Remote Login may be off on this Mac.${R}\n"
      printf "  ${D}Enable: System Settings → General → Sharing → Remote Login${R}\n\n"
    fi

    printf "  ${B}They can now connect with:${R}\n"
    printf "  ${C}ssh -i ~/.killport/id_ed25519 %s@%s${R}\n\n" "$our_user" "$our_ip"
    return
  fi

  # ── error if non-empty non-token arg ─────────────────────────────────────
  if [ -n "$token" ]; then
    printf "\n  ${RE}Unrecognised argument.${R}\n"
    printf "  Usage:\n"
    printf "    killport ssh              generate your token\n"
    printf "    killport ssh ks:<token>   accept a token from another machine\n\n"
    exit 1
  fi

  # ── generate mode ────────────────────────────────────────────────────────
  printf "\n${B}${C}  killport ssh — Key Exchange${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  mkdir -p "$KP_DIR"
  chmod 700 "$KP_DIR"

  if [ ! -f "$KEY_FILE" ]; then
    printf "  Generating Ed25519 keypair...\n"
    ssh-keygen -t ed25519 -f "$KEY_FILE" -N "" -C "killport@$(hostname -s)" -q
    printf "  ${G}✓ Created %s${R}\n\n" "$KEY_FILE"
  else
    printf "  ${D}Using existing key: %s${R}\n\n" "$PUB_FILE"
  fi

  local pubkey local_ip local_user json token_b64
  pubkey=$(cat "$PUB_FILE")
  local_user=$(whoami)
  local_ip=$(ipconfig getifaddr en0 2>/dev/null \
          || ipconfig getifaddr en1 2>/dev/null \
          || ipconfig getifaddr en2 2>/dev/null \
          || echo "unknown")

  json=$(python3 -c "
import json, sys
print(json.dumps({'user': sys.argv[1], 'ip': sys.argv[2], 'pubkey': sys.argv[3]}))
" "$local_user" "$local_ip" "$pubkey")

  token_b64=$(printf '%s' "$json" | base64 | tr -d '\n')

  printf "  ${B}Run this on the other Mac:${R}\n\n"
  printf "  ${C}killport ssh ks:%s${R}\n\n" "$token_b64"
  printf "  ${D}Then connect from this Mac with:${R}\n"
  printf "  ${C}ssh -i ~/.killport/id_ed25519 <their-user>@<their-ip>${R}\n\n"
  printf "  ${D}Your IP on this machine: %s${R}\n\n" "$local_ip"
}

