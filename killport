#!/usr/bin/env bash

set -euo pipefail

VERSION="1.10.25"
REPO="skosari/killport-mac"
RAW="https://raw.githubusercontent.com/${REPO}/main"
API="https://api.github.com/repos/${REPO}/contents"
ANCHOR_FILE="/etc/pf.anchors/killport"

fetch_remote_version() {
  curl -fsSL --max-time "${1:-3}" "${API}/VERSION" 2>/dev/null \
    | grep '"content"' | awk -F'"' '{print $4}' | tr -d '\\n' | base64 -D | tr -d '[:space:]' || true
}

