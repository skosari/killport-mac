}

# ── dns ──────────────────────────────────────────────────

dns_recon() {
  local domain="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  [ -z "$domain" ] && { printf "\n  ${Y}Usage: killport dns <domain>${R}\n\n"; return 1; }

  printf "\n${B}${C}  killport dns${R}  ${D}%s${R}\n" "$domain"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local has_dig=0; command -v dig &>/dev/null && has_dig=1

  _kp_dns_query() {
    local type="$1" tgt="$2"
    if [ "$has_dig" -eq 1 ]; then
      dig +short "$type" "$tgt" 2>/dev/null | grep -v "^$" || true
    else
      host -t "$type" "$tgt" 2>/dev/null | grep -v "NXDOMAIN\|not found\|no.*record" || true
    fi
  }

  _kp_show_recs() {
    local label="$1"; shift
    printf "  ${B}%-8s${R}" "$label"
    local first=1
    while IFS= read -r rec; do
      [ -z "$rec" ] && continue
      if [ "$first" -eq 1 ]; then printf "  ${D}%s${R}\n" "$rec"; first=0
      else printf "  ${D}%8s  %s${R}\n" "" "$rec"; fi
    done
    [ "$first" -eq 1 ] && printf "  ${D}(none)${R}\n" || true
  }

  _kp_dns_query A    "$domain" | _kp_show_recs "A"
  _kp_dns_query AAAA "$domain" | _kp_show_recs "AAAA"
  _kp_dns_query MX   "$domain" | _kp_show_recs "MX"
  _kp_dns_query NS   "$domain" | _kp_show_recs "NS"
  _kp_dns_query TXT  "$domain" | _kp_show_recs "TXT"

  # Reverse DNS for A records
  local a_list=()
  while IFS= read -r ip; do [ -n "$ip" ] && a_list+=("$ip"); done \
    < <(_kp_dns_query A "$domain")
  if [ "${#a_list[@]}" -gt 0 ]; then
    printf "  ${B}%-8s${R}\n" "REVERSE"
    for ip in "${a_list[@]}"; do
      local rev=""
      if [ "$has_dig" -eq 1 ]; then rev=$(dig +short -x "$ip" 2>/dev/null | head -1 || true)
      else rev=$(host "$ip" 2>/dev/null | awk '/domain name/{print $NF}' | head -1 || true); fi
      printf "    ${D}%s  →  %s${R}\n" "$ip" "${rev:-(no PTR)}"
    done
    printf "\n"
  fi

  # Zone transfer test
  printf "  ${B}%-8s${R}\n" "AXFR"
  local ns_list=() axfr_ok=0
  while IFS= read -r ns; do [ -n "$ns" ] && ns_list+=("$ns"); done \
    < <(_kp_dns_query NS "$domain")
  for ns in "${ns_list[@]:-}"; do
    [ -z "$ns" ] && continue
    ns="${ns%.}"
    local axfr_out=""
    if [ "$has_dig" -eq 1 ]; then
      axfr_out=$(dig AXFR "$domain" "@$ns" 2>/dev/null || true)
    else
      axfr_out=$(host -l "$domain" "$ns" 2>/dev/null || true)
    fi
    if [ -n "$axfr_out" ] && echo "$axfr_out" | grep -qE "\bSOA\b|[[:space:]]IN[[:space:]]" \
        && ! echo "$axfr_out" | grep -qE "Transfer failed|REFUSED|timed out|no servers"; then
      printf "    ${RE}⚠  ALLOWED from %s — misconfiguration!${R}\n" "$ns"; axfr_ok=1; fi
  done
  [ "$axfr_ok" -eq 0 ] && printf "    ${G}✓  Zone transfers blocked.${R}\n" || true
  printf "\n"
}

# ── forward ──────────────────────────────────────────────

forward_port() {
  local local_port="${1:-}" target="${2:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  if [ -z "$local_port" ] || [ -z "$target" ]; then
    printf "\n  ${Y}Usage: killport forward <local-port> <host:port>${R}\n"
    printf "  ${D}Example: killport forward 8080 192.168.1.10:80${R}\n\n"; return 1
  fi
  [[ "$target" == *:* ]] || { printf "\n  ${Y}Target must be host:port${R}\n\n"; return 1; }
  local t_host="${target%:*}" t_port="${target##*:}"

  printf "\n${B}${C}  killport forward${R}  ${D}localhost:%s  →  %s${R}\n" "$local_port" "$target"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local _stty; _stty=$(stty -g 2>/dev/null) || _stty=""
  trap '[ -n "$_stty" ] && stty "$_stty" 2>/dev/null || stty sane 2>/dev/null
        printf "\n  ${D}Forward stopped.${R}\n\n"; exit 0' INT TERM

  if command -v socat &>/dev/null; then
    printf "  ${G}✓${R}  ${D}socat${R}  —  forwarding port %s to %s\n" "$local_port" "$target"
    printf "  ${D}Press Ctrl+C to stop.${R}\n\n"
    socat "TCP-LISTEN:${local_port},fork,reuseaddr" "TCP:${t_host}:${t_port}"
  elif command -v nc &>/dev/null; then
    printf "  ${Y}socat not found — using nc (single connection at a time)${R}\n"
    printf "  ${D}Install socat for full support:  brew install socat${R}\n\n"
    printf "  ${D}Press Ctrl+C to stop.${R}\n\n"
    while true; do nc -l "$local_port" | nc "$t_host" "$t_port" || true; done
  else
    printf "  ${RE}Neither socat nor nc found.${R}\n"
    printf "  ${D}Install socat:  brew install socat${R}\n\n"; return 1
  fi
}

# ── fix ──────────────────────────────────────────────────

fix_run() {
  local target="${1:-}"
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  if [ -z "$target" ] || [[ "$target" != *:* ]]; then
    printf "\n  ${Y}Usage: killport fix <ip:port>${R}\n\n"; return 1
  fi
  local ip="${target%:*}" port="${target##*:}"

  command -v nmap &>/dev/null || { printf "\n  ${Y}nmap required:  brew install nmap${R}\n\n"; return 1; }

  printf "\n${B}${C}  killport fix${R}  ${D}%s${R}\n" "$target"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  ${D}Detecting service on port %s...${R}\n\n" "$port"

  local nmap_out svc ver svc_line
  nmap_out=$(nmap -sV -p "$port" --open -T4 "$ip" 2>/dev/null)
  svc_line=$(grep "${port}/tcp" <<< "$nmap_out" | head -1 || true)
  svc=$(awk '{print $3}' <<< "$svc_line" || true)
  ver=$(awk '{$1=$2=$3=""; print $0}' <<< "$svc_line" | sed 's/^ *//' || true)

  if [ -z "$svc" ] || [ "$svc" = "open" ] || [ "$svc" = "filtered" ]; then
    printf "  ${Y}Could not detect service on %s:%s${R}\n\n" "$ip" "$port"; return 1
  fi

  printf "  ${B}Service:${R}  %s\n" "$svc"
  printf "  ${B}Version:${R}  ${D}%s${R}\n\n" "${ver:-unknown}"

  # Detect if target is this machine
  local _is_local=0
  [[ "$ip" == "127."* || "$ip" == "::1" || "$ip" == "localhost" ]] && _is_local=1
  if [ "$_is_local" -eq 0 ]; then
    while IFS= read -r _own; do
      [ "$_own" = "$ip" ] && _is_local=1 && break
    done < <(ifconfig 2>/dev/null | awk '/inet /{gsub("addr:","",$2); print $2}')
  fi

  if [ "$_is_local" -eq 1 ]; then
    printf "  ${G}✓  Target is this machine — can apply fixes directly.${R}\n\n"
  else
    printf "  ${D}Remote target — will generate a fix script to copy over.${R}\n\n"
  fi

  attack_load_conf
  local _ollama="${ATTACK_OLLAMA:-localhost:11434}"
  local _model="${ATTACK_MODEL:-}"

  local _py _script
  _py=$(mktemp "${TMPDIR:-/tmp}/kp_fix.XXXXXX")
  _script=$(mktemp "${TMPDIR:-/tmp}/kp_fix_apply.XXXXXX")

  local _saved_stty; _saved_stty=$(stty -g 2>/dev/null) || _saved_stty=""
  trap 'rm -f "${_py:-}" "${_script:-}" 2>/dev/null; stty sane 2>/dev/null || true' EXIT INT TERM

  cat > "$_py" << 'FIXPYEOF'
