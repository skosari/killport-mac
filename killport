  local host="${target%:*}" port="${target##*:}"
  printf "\n${B}${C}  killport vuln${R}  ${D}%s${R}\n" "$target"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"
  printf "  ${D}Detecting service on port %s...${R}\n\n" "$port"

  local nmap_out; nmap_out=$(nmap -sV -p "$port" --open -T4 "$host" 2>/dev/null)
  local svc_line; svc_line=$(grep "${port}/tcp" <<< "$nmap_out" | head -1 || true)
  local svc; svc=$(awk '{print $3}' <<< "$svc_line")
  local ver; ver=$(awk '{$1=$2=$3=""; print $0}' <<< "$svc_line" | sed 's/^ *//')

  if [ -z "$svc" ] || [ "$svc" = "open" ]; then
    printf "  ${Y}Could not detect service on %s:%s${R}\n\n" "$host" "$port"; return 1
  fi

  printf "  ${B}Service:${R}  %s\n" "$svc"
  printf "  ${B}Version:${R}  ${D}%s${R}\n\n" "${ver:-unknown}"
  printf "  ${D}Querying NVD database...${R}\n\n"

  local query="${svc} ${ver%% *}"
  local enc_query; enc_query=$(python3 -c \
    "import urllib.parse,sys; print(urllib.parse.quote(sys.argv[1]))" \
    "$query" 2>/dev/null || printf '%s' "$query" | sed 's/ /+/g')
  local nvd_resp; nvd_resp=$(curl -sfL --max-time 12 \
    "https://services.nvd.nist.gov/rest/json/cves/2.0?keywordSearch=${enc_query}&resultsPerPage=10" \
    2>/dev/null || true)

  if [ -z "$nvd_resp" ]; then
    printf "  ${Y}Could not reach NVD API (check internet connection).${R}\n\n"; return 1
  fi

  python3 - "$nvd_resp" << 'VULNEOF'
import sys, json
data = sys.argv[1]
B="\033[1m"; D="\033[2m"; G="\033[0;32m"; Y="\033[0;33m"; RE="\033[0;31m"; R="\033[0m"
SC={"CRITICAL":RE,"HIGH":RE,"MEDIUM":Y,"LOW":G,"NONE":D}
try:
    obj = json.loads(data)
    vulns = obj.get("vulnerabilities",[])
    total = obj.get("totalResults", len(vulns))
    if not vulns:
        print(f"  {G}No CVEs found for this service/version.{R}\n"); sys.exit(0)
    print(f"  {B}{total}{R} CVE(s) found — showing top {len(vulns)}:\n")
    for v in vulns:
        c = v.get("cve",{})
        cid = c.get("id","?")
        desc = next((d["value"] for d in c.get("descriptions",[]) if d.get("lang")=="en"),"")[:120]
        sev,score="UNKNOWN",""
        for mk in ("cvssMetricV31","cvssMetricV30","cvssMetricV2"):
            if mk in c.get("metrics",{}):
                m0=c["metrics"][mk][0]; cd=m0.get("cvssData",{})
                sev=cd.get("baseSeverity",m0.get("baseSeverity","?")); score=str(cd.get("baseScore",""))
                break
        sc=SC.get(sev.upper(),D)
        print(f"  {B}{cid}{R}  {sc}[{sev}  {score}]{R}")
        print(f"  {D}{desc}{'...' if len(desc)==120 else ''}{R}\n")
except Exception as e:
    print(f"  Error parsing CVE data: {e}")
VULNEOF
}

# ── audit ────────────────────────────────────────────────

audit_firewall() {
  local C=$'\033[0;36m' G=$'\033[0;32m' Y=$'\033[0;33m'
  local RE=$'\033[0;31m' D=$'\033[2m' B=$'\033[1m' R=$'\033[0m'

  printf "\n${B}${C}  killport audit${R}  ${D}firewall rule review${R}\n"
  printf "${C}  ────────────────────────────────────────────${R}\n\n"

  local rules=""
  printf "  ${D}Loading firewall rules...${R}\n"
  rules=$(sudo -p "  Password: " pfctl -sr 2>/dev/null || sudo -p "  Password: " pfctl -s rules 2>/dev/null || true)

  if [ -z "$rules" ]; then
    printf "  ${Y}No firewall rules found (pfctl returned nothing or insufficient permissions).${R}\n"
    printf "  ${D}Try: sudo killport audit${R}\n\n"; return 0
  fi

  printf "  ${B}Rules:${R}\n\n"
  while IFS= read -r line; do [ -n "$line" ] && printf "  ${D}  %s${R}\n" "$line"; done <<< "$rules"
  printf "\n  ${B}Findings:${R}\n\n"

  local findings=0
  # Catch-all accept
  if grep -qiE "^pass (all|in all|out all)" <<< "$rules"; then
    printf "  ${RE}⚠  Catch-all pass rule — all traffic is allowed by default.${R}\n"; findings=1; fi
  # Dangerous exposed ports
  for dp_port in 22 3306 5432 6379 27017 9200 11211; do
    if grep -qE "\b${dp_port}\b" <<< "$rules"; then
      local sn=""
      case "$dp_port" in 22) sn="SSH";; 3306) sn="MySQL";; 5432) sn="PostgreSQL";;
        6379) sn="Redis";; 27017) sn="MongoDB";; 9200) sn="Elasticsearch";; 11211) sn="Memcached";; esac
      printf "  ${Y}⚠  Port %s (%s) referenced — confirm it's restricted to trusted IPs.${R}\n" "$dp_port" "$sn"
      findings=1
    fi
  done
  # Logging
  if grep -qi "log" <<< "$rules"; then
    printf "  ${G}✓  Logging rules present.${R}\n"
  else
    printf "  ${Y}⚠  No logging rules — consider adding 'log' to firewall rules.${R}\n"; findings=1; fi
  # Tables (allowlists)
  if grep -qi "<" <<< "$rules"; then
    printf "  ${G}✓  IP tables/allowlists in use.${R}\n"; fi

