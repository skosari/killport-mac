#!/usr/bin/env bash

set -euo pipefail

REPO_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SRC="$REPO_DIR/killport"
DEST="/usr/local/bin/killport"

if [[ ! -f "$SRC" ]]; then
  echo "Error: $SRC not found" >&2
  exit 1
fi

VERSION=$(grep -m1 'VERSION=' "$SRC" | head -1 | cut -d'"' -f2 || cat "$REPO_DIR/VERSION" 2>/dev/null || echo "unknown")

if [[ -w "$DEST" || -w "$(dirname "$DEST")" ]]; then
  cp "$SRC" "$DEST"
  chmod +x "$DEST"
else
  sudo cp "$SRC" "$DEST"
  sudo chmod +x "$DEST"
fi

echo "Deployed killport $VERSION → $DEST"
